{% extends "layout.twig" %}

{% block content %}
  <div class="page-header">
    <div>
      <span class="eyebrow">Accounts</span>
      <h1 class="page-title">{{ account.id ? 'Edit account' : 'Add account' }}</h1>
      <p class="page-subtitle muted">Manage the identity and credentials used for publishing.</p>
    </div>
  </div>
  <div class="card" style="max-width: 720px;">
    {% if error %}
      <p class="status-pill">{{ error }}</p>
    {% endif %}
    <form method="post" action="{{ base_path }}{{ action }}" class="form-stack">
      <input type="hidden" name="_csrf" value="{{ csrf }}" />
      <label>
        Platform
        <input type="text" name="platform" value="{{ account.platform }}" required />
      </label>
      <label>
        Display name
        <input type="text" name="display_name" value="{{ account.display_name }}" required />
      </label>
      <label>
        Handle
        <input type="text" name="handle" value="{{ account.handle }}" required />
      </label>
      <label>
        OAuth token{% if token_optional %} (leave blank to keep existing){% endif %}
        <input type="password" name="oauth_token" />
      </label>
      <label>
        OAuth token secret (X OAuth 1.0a)
        <input type="password" name="oauth_token_secret" />
      </label>
      <label class="checkbox-row">
        <input type="checkbox" name="is_active" {% if account.is_active %}checked{% endif %} />
        Active
      </label>
      <div class="actions-row">
        <button type="submit">Save</button>
        <a href="{{ base_path }}/accounts">Cancel</a>
      </div>
    </form>
  </div>
{% endblock %}

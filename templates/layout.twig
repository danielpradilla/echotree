<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ title }}</title>
    <style>
      :root {
        --bg: #ffffff;
        --bg-accent: #f6fbf3;
        --ink: #0b5d1e;
        --accent: #5aaa95;
        --accent-strong: #3f8d79;
        --muted: #467363;
        --card: rgba(255, 255, 255, 0.96);
        --card-solid: #ffffff;
        --surface-panel: rgba(255, 255, 255, 0.72);
        --surface-panel-strong: rgba(255, 255, 255, 0.92);
        --surface-panel-warm: rgba(255, 253, 249, 0.72);
        --surface-hover: rgba(246, 251, 243, 0.92);
        --border: rgba(11, 93, 30, 0.16);
        --line-soft: rgba(90, 170, 149, 0.24);
        --selection: rgba(194, 232, 18, 0.24);
        --field: #ffffff;
        --on-accent: #fff8f2;
        --danger: #a12a2a;
        --danger-soft: rgba(191, 62, 62, 0.12);
        --warning: #7a6100;
        --warning-soft: rgba(247, 203, 21, 0.18);
        --neutral-soft: rgba(70, 115, 99, 0.12);
        --stale: #cc3d2b;
        --stale-soft: rgba(204, 61, 43, 0.14);
        --shadow: rgba(11, 93, 30, 0.12);
        --shadow-soft: rgba(11, 93, 30, 0.06);
        --font-xs: 9px;
        --font-sm: 11px;
        --font-md: 13px;
        --font-lg: 15px;
        --font-xl: 17px;
        --font-xxl: 21px;
        --radius-card: 18px;
        --radius-panel: 16px;
        --radius-control: 10px;
        --radius-compact: 8px;
        --radius-pill: 999px;
        --app-header-height: 42px;
        --app-main-gutter: 18px;
        --app-main-top-gap: 8px;
        --app-main-bottom-gap: 28px;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Palatino, Georgia, serif;
        font-size: var(--font-md);
        background:
          radial-gradient(circle at top left, rgba(247, 203, 21, 0.12), transparent 24%),
          radial-gradient(circle at bottom right, rgba(90, 170, 149, 0.08), transparent 30%),
          linear-gradient(180deg, var(--bg) 0%, var(--bg-accent) 100%);
        background-color: var(--bg);
        color: var(--ink);
      }
      body.layout--bare {
        min-height: 100vh;
      }
      h1, h2, h3, h4, h5, h6, p {
        margin-top: 0;
      }
      h1, h2, h3 {
        letter-spacing: -0.02em;
      }
      h1 {
        font-size: var(--font-xxl);
      }
      h2 {
        font-size: var(--font-xl);
      }
      h3 {
        font-size: var(--font-lg);
      }
      p {
        line-height: 1.65;
      }
      header {
        border-bottom: 1px solid var(--border);
        padding: 5px 12px;
        background: rgba(255, 255, 255, 0.92);
        backdrop-filter: blur(12px);
        position: sticky;
        top: 0;
        z-index: 10;
        min-height: var(--app-header-height);
      }
      main {
        max-width: 1560px;
        margin: var(--app-main-top-gap) auto var(--app-main-bottom-gap);
        padding: 0 var(--app-main-gutter);
      }
      .main--bare {
        max-width: 680px;
        min-height: 100vh;
        margin: 0 auto;
        padding: 40px 20px;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: var(--radius-card);
        padding: 24px;
        box-shadow: 0 18px 40px var(--shadow);
      }
      .hero-card {
        padding: 32px;
        background: rgba(255, 255, 255, 0.98);
        border-color: rgba(90, 170, 149, 0.22);
      }
      .accent { color: var(--accent); }
      .muted { color: var(--muted); }
      a {
        color: var(--accent);
        text-underline-offset: 0.18em;
      }
      a:hover { color: var(--accent-strong); }
      button,
      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: var(--accent);
        color: var(--on-accent);
        border: 1px solid var(--accent);
        padding: 5px 10px 4px;
        border-radius: var(--radius-control);
        cursor: pointer;
        font: inherit;
        font-size: var(--font-sm);
        line-height: 1;
        min-height: 24px;
        text-decoration: none;
        transition: background 120ms ease, transform 120ms ease, border-color 120ms ease;
      }
      button:hover,
      .button:hover {
        background: var(--accent-strong);
        border-color: var(--accent-strong);
        color: var(--on-accent);
        transform: translateY(-1px);
      }
      .button-secondary {
        background: transparent;
        color: var(--ink);
        border-color: var(--border);
      }
      .button-secondary:hover {
        background: var(--surface-hover);
        border-color: var(--accent);
      }
      input, select, textarea {
        border: 1px solid var(--border);
        border-radius: var(--radius-control);
        padding: 8px 10px;
        font: inherit;
        background: var(--field);
        color: var(--ink);
      }
      input:focus, select:focus, textarea:focus {
        outline: 2px solid rgba(90, 170, 149, 0.22);
        border-color: var(--accent);
      }
      textarea {
        resize: vertical;
      }
      label {
        display: block;
        font-size: var(--font-md);
        color: var(--muted);
      }
      label input, label select, label textarea {
        display: block;
        width: 100%;
        margin-top: 8px;
      }
      hr {
        border: 0;
        border-top: 1px solid var(--line-soft);
      }
      fieldset {
        border: 0;
        padding: 0;
        margin: 0;
        min-width: 0;
      }
      legend {
        padding: 0;
        margin-bottom: 8px;
        color: var(--ink);
        font-weight: 600;
      }
      table th {
        color: var(--muted);
        font-weight: 600;
        border-bottom: 1px solid var(--line-soft);
      }
      table td {
        border-bottom: 1px solid rgba(216, 197, 175, 0.55);
      }
      table tr:last-child td {
        border-bottom: 0;
      }
      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
      }
      .brand {
        display: flex;
        align-items: baseline;
        gap: 10px;
        flex-wrap: wrap;
      }
      .brand__name {
        font-size: var(--font-lg);
        letter-spacing: -0.03em;
      }
      .nav {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
      }
      .nav-toggle {
        display: none;
        align-items: center;
        justify-content: center;
        width: 44px;
        height: 44px;
        padding: 0;
        border-radius: 12px;
      }
      .nav-toggle__icon {
        position: relative;
        width: 18px;
        height: 2px;
        background: currentColor;
        border-radius: var(--radius-pill);
      }
      .nav-toggle__icon::before,
      .nav-toggle__icon::after {
        content: "";
        position: absolute;
        left: 0;
        width: 18px;
        height: 2px;
        background: currentColor;
        border-radius: var(--radius-pill);
      }
      .nav-toggle__icon::before { top: -6px; }
      .nav-toggle__icon::after { top: 6px; }
      .nav a {
        text-decoration: none;
        padding: 5px 9px;
        border-radius: var(--radius-pill);
        border: 1px solid transparent;
      }
      .nav a:hover {
        background: rgba(255, 250, 243, 0.8);
        border-color: var(--line-soft);
      }
      .nav__spacer {
        flex: 1 1 auto;
      }
      .page-header {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 16px;
        flex-wrap: wrap;
        margin-bottom: 14px;
      }
      .page-title {
        margin: 10px 0;
        font-size: var(--font-xxl);
        line-height: 1.2;
      }
      .page-subtitle {
        max-width: 52ch;
        margin-bottom: 0;
        font-size: var(--font-md);
        line-height: 1.45;
      }
      .actions-row {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
      }
      .stack {
        display: flex;
        flex-direction: column;
        gap: 18px;
      }
      .form-stack {
        display: flex;
        flex-direction: column;
        gap: 18px;
      }
      .checkbox-row {
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--ink);
      }
      .checkbox-row input {
        width: auto;
        margin: 0;
      }
      .table-shell {
        border: 1px solid var(--line-soft);
        border-radius: var(--radius-panel);
        overflow: hidden;
        background: var(--surface-panel-warm);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.55);
      }
      .table-shell table {
        width: 100%;
        border-collapse: collapse;
      }
      .table-shell th,
      .table-shell td {
        padding: 14px 16px;
        text-align: left;
        vertical-align: top;
      }
      .eyebrow {
        display: inline-block;
        margin-bottom: 12px;
        color: #3f8d79;
        font-size: var(--font-xs);
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }
      .badge,
      .status-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 10px;
        border-radius: var(--radius-pill);
        background: rgba(194, 232, 18, 0.22);
        color: #0b5d1e;
        font-size: var(--font-xs);
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }
      .badge--compact,
      .scheduled__badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border-radius: var(--radius-pill);
        padding: 2px 8px;
        font-size: var(--font-xs);
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        white-space: nowrap;
      }
      .badge--neutral,
      .scheduled__badge--neutral {
        background: var(--neutral-soft);
        color: var(--muted);
      }
      .badge--success,
      .scheduled__badge--success {
        background: color-mix(in srgb, var(--accent) 14%, transparent);
        color: var(--accent-strong);
      }
      .badge--warning,
      .scheduled__badge--warning {
        background: var(--warning-soft);
        color: var(--warning);
      }
      .badge--danger,
      .scheduled__badge--danger {
        background: var(--danger-soft);
        color: var(--danger);
      }
      .empty-state {
        padding: 28px;
        border: 1px dashed var(--border);
        border-radius: var(--radius-panel);
        background: rgba(255, 250, 243, 0.55);
      }
      .panel {
        border: 1px solid var(--line-soft);
        border-radius: var(--radius-panel);
        background: var(--surface-panel);
      }
      .panel--warm {
        background: var(--surface-panel-warm);
      }
      .panel--selected {
        background: var(--selection);
      }
      .split-callout {
        display: grid;
        grid-template-columns: 1.5fr 1fr;
        gap: 18px;
        align-items: start;
      }
      .callout-panel {
        padding: 18px;
        border-radius: var(--radius-panel);
        background: var(--surface-panel-warm);
        border: 1px solid var(--line-soft);
        box-shadow: 0 10px 24px var(--shadow-soft);
      }
      .inline-form {
        display: inline;
      }
      @media (max-width: 900px) {
        :root {
          --app-header-height: 58px;
          --app-main-gutter: 8px;
          --app-main-top-gap: 6px;
          --app-main-bottom-gap: 16px;
        }
        .topbar {
          align-items: center;
        }
        header {
          padding: 7px 10px;
        }
        main {
          margin-top: var(--app-main-top-gap);
          padding: 0 var(--app-main-gutter) var(--app-main-bottom-gap);
        }
        .card, .hero-card {
          padding: 16px;
        }
        .page-header {
          align-items: start;
        }
        .split-callout {
          grid-template-columns: 1fr;
        }
        .nav-toggle {
          display: inline-flex;
        }
        .nav {
          display: none;
          width: 100%;
          flex-direction: column;
          align-items: stretch;
          gap: 6px;
          margin-top: 8px;
          padding-top: 12px;
          border-top: 1px solid var(--line-soft);
        }
        .nav.is-open {
          display: flex;
        }
        .nav a {
          width: 100%;
          padding: 10px 12px;
          border-radius: 12px;
          border-color: var(--line-soft);
          background: rgba(246, 251, 243, 0.7);
        }
      }
    </style>
  </head>
  <body class="{% if hide_app_chrome %}layout--bare{% endif %}">
    {% if not hide_app_chrome %}
      <header>
        <div class="topbar">
          <div class="brand">
            <strong class="brand__name">EchoTree</strong>
            {% if app_commit %}
              <span class="muted" style="font-size: 12px;">({{ app_commit }})</span>
            {% endif %}
            <span class="muted">/ {{ title }}</span>
          </div>
          <button type="button" class="nav-toggle button-secondary" aria-expanded="false" aria-controls="site-nav" aria-label="Toggle navigation">
            <span class="nav-toggle__icon"></span>
          </button>
          <nav class="nav" id="site-nav">
            <a href="{{ base_path ~ '/' }}">Home</a>
            <a href="{{ base_path }}/feeds">Feeds</a>
            <a href="{{ base_path }}/articles">Reader</a>
            <a href="{{ base_path }}/share">Share</a>
            <a href="{{ base_path }}/scheduled">Scheduled</a>
            <a href="{{ base_path }}/history">History</a>
            <a href="{{ base_path }}/accounts">Accounts</a>
            <span class="nav__spacer" aria-hidden="true"></span>
            <a href="{{ base_path }}/logout">Logout</a>
          </nav>
        </div>
      </header>
    {% endif %}
    <main class="{% if hide_app_chrome %}main--bare{% endif %}">
      {% block content %}{% endblock %}
    </main>
    {% if not hide_app_chrome %}
      <script>
        (function () {
          var toggle = document.querySelector('.nav-toggle');
          var nav = document.getElementById('site-nav');
          if (!toggle || !nav) return;

          function syncState() {
            if (window.innerWidth > 900) {
              nav.classList.remove('is-open');
              toggle.setAttribute('aria-expanded', 'false');
            }
          }

          toggle.addEventListener('click', function () {
            var isOpen = nav.classList.toggle('is-open');
            toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
          });

          window.addEventListener('resize', syncState);
          syncState();
        })();
      </script>
    {% endif %}
  </body>
</html>

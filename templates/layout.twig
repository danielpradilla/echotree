<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ title }}</title>
    <style>
      :root {
        --bg: #ffffff;
        --bg-accent: #f6fbf3;
        --ink: #0b5d1e;
        --accent: #5aaa95;
        --accent-strong: #3f8d79;
        --muted: #467363;
        --card: rgba(255, 255, 255, 0.96);
        --card-solid: #ffffff;
        --border: rgba(11, 93, 30, 0.16);
        --line-soft: rgba(90, 170, 149, 0.24);
        --selection: rgba(194, 232, 18, 0.24);
        --field: #ffffff;
        --shadow: rgba(11, 93, 30, 0.12);
        --shadow-soft: rgba(11, 93, 30, 0.06);
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Palatino, Georgia, serif;
        background:
          radial-gradient(circle at top left, rgba(247, 203, 21, 0.12), transparent 24%),
          radial-gradient(circle at bottom right, rgba(90, 170, 149, 0.08), transparent 30%),
          linear-gradient(180deg, var(--bg) 0%, var(--bg-accent) 100%);
        background-color: var(--bg);
        color: var(--ink);
      }
      h1, h2, h3, h4, h5, h6, p {
        margin-top: 0;
      }
      h1, h2, h3 {
        letter-spacing: -0.02em;
      }
      p {
        line-height: 1.65;
      }
      header {
        border-bottom: 1px solid var(--border);
        padding: 16px 24px;
        background: rgba(255, 255, 255, 0.92);
        backdrop-filter: blur(12px);
        position: sticky;
        top: 0;
        z-index: 10;
      }
      main {
        max-width: 1400px;
        margin: 36px auto 48px;
        padding: 0 28px;
      }
      .card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 18px;
        padding: 24px;
        box-shadow: 0 18px 40px var(--shadow);
      }
      .hero-card {
        padding: 32px;
        background: rgba(255, 255, 255, 0.98);
        border-color: rgba(90, 170, 149, 0.22);
      }
      .accent { color: var(--accent); }
      .muted { color: var(--muted); }
      a {
        color: var(--accent);
        text-underline-offset: 0.18em;
      }
      a:hover { color: var(--accent-strong); }
      button {
        background: var(--accent);
        color: #fff8f2;
        border: 1px solid var(--accent);
        padding: 8px 14px;
        border-radius: 999px;
        cursor: pointer;
        transition: background 120ms ease, transform 120ms ease, border-color 120ms ease;
      }
      button:hover {
        background: var(--accent-strong);
        border-color: var(--accent-strong);
        transform: translateY(-1px);
      }
      .button-secondary {
        background: transparent;
        color: var(--ink);
        border-color: var(--border);
      }
      .button-secondary:hover {
        background: rgba(246, 251, 243, 0.92);
        border-color: var(--accent);
      }
      input, select, textarea {
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 8px 10px;
        font: inherit;
        background: var(--field);
        color: var(--ink);
      }
      input:focus, select:focus, textarea:focus {
        outline: 2px solid rgba(90, 170, 149, 0.22);
        border-color: var(--accent);
      }
      textarea {
        resize: vertical;
      }
      label {
        display: block;
        font-size: 14px;
        color: var(--muted);
      }
      label input, label select, label textarea {
        display: block;
        width: 100%;
        margin-top: 8px;
      }
      hr {
        border: 0;
        border-top: 1px solid var(--line-soft);
      }
      fieldset {
        border: 0;
        padding: 0;
        margin: 0;
        min-width: 0;
      }
      legend {
        padding: 0;
        margin-bottom: 8px;
        color: var(--ink);
        font-weight: 600;
      }
      table th {
        color: var(--muted);
        font-weight: 600;
        border-bottom: 1px solid var(--line-soft);
      }
      table td {
        border-bottom: 1px solid rgba(216, 197, 175, 0.55);
      }
      table tr:last-child td {
        border-bottom: 0;
      }
      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
      }
      .brand {
        display: flex;
        align-items: baseline;
        gap: 10px;
        flex-wrap: wrap;
      }
      .brand__name {
        font-size: 24px;
        letter-spacing: -0.03em;
      }
      .nav {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
      }
      .nav a {
        text-decoration: none;
        padding: 7px 12px;
        border-radius: 999px;
        border: 1px solid transparent;
      }
      .nav a:hover {
        background: rgba(255, 250, 243, 0.8);
        border-color: var(--line-soft);
      }
      .page-header {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 16px;
        flex-wrap: wrap;
        margin-bottom: 14px;
      }
      .page-title {
        margin-bottom: 2px;
        font-size: clamp(26px, 2.5vw, 36px);
      }
      .page-subtitle {
        max-width: 52ch;
        margin-bottom: 0;
        font-size: 15px;
        line-height: 1.45;
      }
      .actions-row {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
      }
      .stack {
        display: flex;
        flex-direction: column;
        gap: 18px;
      }
      .form-stack {
        display: flex;
        flex-direction: column;
        gap: 18px;
      }
      .checkbox-row {
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--ink);
      }
      .checkbox-row input {
        width: auto;
        margin: 0;
      }
      .table-shell {
        border: 1px solid var(--line-soft);
        border-radius: 16px;
        overflow: hidden;
        background: rgba(255, 253, 249, 0.72);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.55);
      }
      .table-shell table {
        width: 100%;
        border-collapse: collapse;
      }
      .table-shell th,
      .table-shell td {
        padding: 14px 16px;
        text-align: left;
        vertical-align: top;
      }
      .eyebrow {
        display: inline-block;
        margin-bottom: 12px;
        color: #3f8d79;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }
      .status-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 10px;
        border-radius: 999px;
        background: rgba(194, 232, 18, 0.22);
        color: #0b5d1e;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }
      .empty-state {
        padding: 28px;
        border: 1px dashed var(--border);
        border-radius: 16px;
        background: rgba(255, 250, 243, 0.55);
      }
      .split-callout {
        display: grid;
        grid-template-columns: 1.5fr 1fr;
        gap: 18px;
        align-items: start;
      }
      .callout-panel {
        padding: 18px;
        border-radius: 16px;
        background: rgba(255, 253, 249, 0.72);
        border: 1px solid var(--line-soft);
        box-shadow: 0 10px 24px var(--shadow-soft);
      }
      .inline-form {
        display: inline;
      }
      @media (max-width: 900px) {
        header {
          padding: 14px 16px;
        }
        main {
          margin-top: 24px;
          padding: 0 16px 32px;
        }
        .card, .hero-card {
          padding: 20px;
        }
        .page-header {
          align-items: start;
        }
        .split-callout {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="topbar">
        <div class="brand">
          <strong class="brand__name">EchoTree</strong>
          {% if app_commit %}
            <span class="muted" style="font-size: 12px;">({{ app_commit }})</span>
          {% endif %}
          <span class="muted">/ {{ title }}</span>
        </div>
        <nav class="nav">
          <a href="{{ base_path ~ '/' }}">Home</a>
          <a href="{{ base_path }}/feeds">Feeds</a>
          <a href="{{ base_path }}/articles">Articles</a>
          <a href="{{ base_path }}/share">Share</a>
          <a href="{{ base_path }}/scheduled">Scheduled</a>
          <a href="{{ base_path }}/accounts">Accounts</a>
          <a href="{{ base_path }}/logout">Logout</a>
        </nav>
      </div>
    </header>
    <main>
      {% block content %}{% endblock %}
    </main>
  </body>
</html>

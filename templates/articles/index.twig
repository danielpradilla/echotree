{% extends "layout.twig" %}

{% block content %}
  <style>
    .reader-page {
      margin-top: -8px;
    }
    .reader-app {
      background: rgba(255, 255, 255, 0.72);
      border: 1px solid rgba(11, 93, 30, 0.1);
      border-radius: 22px;
      box-shadow: 0 24px 48px rgba(11, 93, 30, 0.1);
      overflow: hidden;
    }
    .reader-topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      padding: 14px 18px;
      border-bottom: 1px solid var(--line-soft);
      background: rgba(247, 248, 243, 0.94);
    }
    .reader-topbar__title {
      font-size: 20px;
      letter-spacing: -0.02em;
    }
    .reader-topbar__controls {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }
    .toggle-group {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 4px;
      border: 1px solid var(--border);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.88);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.72);
    }
    .toggle-chip {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      min-width: 40px;
      padding: 7px 10px;
      border: 1px solid transparent;
      border-radius: 999px;
      background: transparent;
      color: var(--muted);
      text-decoration: none;
      font-size: 13px;
      line-height: 1;
    }
    .toggle-chip:hover {
      background: rgba(90, 170, 149, 0.08);
      color: var(--ink);
    }
    .toggle-chip.is-selected {
      background: var(--accent);
      border-color: var(--accent);
      color: #fff;
      box-shadow: 0 6px 16px rgba(11, 93, 30, 0.16);
    }
    .toggle-chip__icon {
      width: 14px;
      height: 14px;
      display: inline-block;
      position: relative;
      flex: 0 0 auto;
    }
    .toggle-chip--density-compact .toggle-chip__icon::before,
    .toggle-chip--density-compact .toggle-chip__icon::after,
    .toggle-chip--density-comfortable .toggle-chip__icon::before,
    .toggle-chip--density-comfortable .toggle-chip__icon::after,
    .toggle-chip--layout-split .toggle-chip__icon::before,
    .toggle-chip--layout-split .toggle-chip__icon::after,
    .toggle-chip--layout-magazine .toggle-chip__icon::before,
    .toggle-chip--layout-magazine .toggle-chip__icon::after,
    .toggle-chip--layout-grid .toggle-chip__icon::before,
    .toggle-chip--layout-grid .toggle-chip__icon::after {
      content: "";
      position: absolute;
      background: currentColor;
      border-radius: 2px;
    }
    .toggle-chip--density-compact .toggle-chip__icon::before {
      inset: 1px 1px 8px 1px;
    }
    .toggle-chip--density-compact .toggle-chip__icon::after {
      inset: 9px 1px 1px 1px;
    }
    .toggle-chip--density-comfortable .toggle-chip__icon::before {
      inset: 1px 1px 10px 1px;
    }
    .toggle-chip--density-comfortable .toggle-chip__icon::after {
      inset: 11px 1px 1px 1px;
    }
    .toggle-chip--layout-split .toggle-chip__icon::before {
      left: 1px;
      top: 1px;
      bottom: 1px;
      width: 4px;
    }
    .toggle-chip--layout-split .toggle-chip__icon::after {
      right: 1px;
      top: 1px;
      bottom: 1px;
      width: 7px;
    }
    .toggle-chip--layout-magazine .toggle-chip__icon::before {
      left: 1px;
      top: 1px;
      bottom: 1px;
      width: 5px;
    }
    .toggle-chip--layout-magazine .toggle-chip__icon::after {
      right: 1px;
      top: 3px;
      bottom: 3px;
      width: 6px;
    }
    .toggle-chip--layout-grid .toggle-chip__icon {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: repeat(2, 1fr);
      gap: 2px;
    }
    .toggle-chip--layout-grid .toggle-chip__icon::before,
    .toggle-chip--layout-grid .toggle-chip__icon::after {
      display: none;
    }
    .toggle-chip--layout-grid .toggle-chip__icon span {
      display: block;
      background: currentColor;
      border-radius: 2px;
    }
    .reader-shell {
      display: grid;
      grid-template-columns: 220px 420px minmax(0, 1fr);
      gap: 0;
    }
    .reader-panel {
      min-height: 0;
    }
    .reader-panel--nav,
    .reader-panel--stories {
      max-height: calc(100vh - 220px);
      overflow: auto;
      background: rgba(245, 245, 239, 0.82);
    }
    .reader-panel--nav {
      border-right: 1px solid var(--line-soft);
      padding: 14px 10px 18px;
    }
    .reader-panel--stories {
      border-right: 1px solid var(--line-soft);
      padding: 14px 12px 18px;
      background: rgba(255, 255, 255, 0.92);
    }
    .reader-panel--main {
      background: rgba(255, 255, 255, 0.96);
      padding: 14px 16px 18px;
    }
    .story-item,
    .site-item {
      padding: 10px 8px;
      border-bottom: 1px solid var(--line-soft);
    }
    .story-list--compact .story-item {
      padding: 6px 8px;
    }
    .story-list--compact .story-title-row {
      gap: 6px;
    }
    .story-list--compact .story-item strong {
      font-size: 14px;
      line-height: 1.35;
    }
    .story-list--compact .story-item .muted {
      font-size: 11px !important;
    }
    .story-item a,
    .site-item a {
      text-decoration: none;
      display: block;
    }
    .story-item.active,
    .site-item.active {
      background: var(--selection);
      border-radius: 12px;
    }
    .site-item {
      border-bottom: 0;
      margin-bottom: 4px;
    }
    .site-link {
      display: grid !important;
      grid-template-columns: 20px minmax(0, 1fr);
      gap: 10px;
      align-items: start;
    }
    .site-favicon {
      width: 18px;
      height: 18px;
      border-radius: 4px;
      background: rgba(90, 170, 149, 0.14);
      border: 1px solid rgba(11, 93, 30, 0.08);
      object-fit: cover;
      margin-top: 1px;
    }
    .site-item.active {
      box-shadow: inset 3px 0 0 #84b316;
    }
    .story-item {
      border: 1px solid transparent;
      border-radius: 14px;
      margin-bottom: 8px;
      background: rgba(255, 255, 255, 0.78);
    }
    .story-item.active {
      border-color: rgba(132, 179, 22, 0.22);
      box-shadow: 0 10px 24px rgba(11, 93, 30, 0.06);
    }
    .story-list--grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }
    .story-list--grid .story-item {
      margin-bottom: 0;
      height: 100%;
    }
    .story-list--grid .story-card-link {
      grid-template-columns: 1fr;
    }
    .story-list--grid .story-thumb {
      width: 100%;
      aspect-ratio: 1.45;
    }
    .story-list--grid .story-summary {
      -webkit-line-clamp: 4;
    }
    .story-list--magazine .story-thumb {
      width: 124px;
      aspect-ratio: 0.78;
    }
    .story-list--magazine .story-card-link {
      grid-template-columns: 124px minmax(0, 1fr);
      gap: 14px;
    }
    .story-card-link {
      display: grid !important;
      grid-template-columns: 92px minmax(0, 1fr);
      gap: 12px;
      align-items: start;
    }
    .story-thumb {
      width: 92px;
      aspect-ratio: 0.72;
      border-radius: 12px;
      overflow: hidden;
      background:
        linear-gradient(160deg, rgba(247, 203, 21, 0.24), rgba(90, 170, 149, 0.18)),
        rgba(248, 249, 244, 0.96);
      border: 1px solid rgba(11, 93, 30, 0.08);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--muted);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .story-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .story-thumb--compact {
      width: 52px;
      border-radius: 10px;
    }
    .story-content {
      min-width: 0;
    }
    .story-summary {
      margin-top: 6px;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.4;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 3;
      overflow: hidden;
    }
    .story-list--compact .story-card-link {
      grid-template-columns: 52px minmax(0, 1fr);
      gap: 10px;
    }
    .article-source {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: 8px;
      font-size: 12px;
      color: var(--muted);
    }
    .source-dot {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      flex: 0 0 auto;
    }
    .reader-viewer {
      display: flex;
      flex-direction: column;
      gap: 16px;
      min-height: 400px;
      min-width: 0;
    }
    .reader-stage {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 320px;
      gap: 16px;
      align-items: start;
    }
    .reader-stage__article {
      min-width: 0;
    }
    .reader-stage__compose {
      position: sticky;
      top: 12px;
    }
    .inbox__iframe {
      width: 100%;
      height: 72vh;
      border: 1px solid var(--border);
      border-radius: 14px;
      background: var(--card-solid);
    }
    .panel-toolbar {
      display: flex;
      justify-content: space-between;
      align-items: end;
      gap: 12px;
      margin-bottom: 10px;
      flex-wrap: wrap;
    }
    .story-toolbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      margin-bottom: 12px;
    }
    .inbox__meta {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }
    .panel-kicker {
      margin-bottom: 10px;
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .site-title-row,
    .story-title-row {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: baseline;
    }
    .count-pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 28px;
      padding: 2px 8px;
      border-radius: 999px;
      background: rgba(90, 170, 149, 0.12);
      color: var(--muted);
      font-size: 12px;
    }
    .reader-meta-card {
      padding: 14px 16px;
      border: 1px solid var(--line-soft);
      border-radius: 16px;
      background: rgba(248, 249, 244, 0.92);
    }
    @media (max-width: 900px) {
      .reader-topbar {
        padding: 12px 14px;
      }
      .reader-shell { grid-template-columns: 1fr; }
      .reader-panel--nav,
      .reader-panel--stories { max-height: none; border-right: 0; padding-right: 0; }
      .reader-panel--main {
        padding: 14px 12px 18px;
      }
      .reader-stage {
        grid-template-columns: 1fr;
      }
      .reader-stage__compose {
        position: static;
      }
      .inbox__iframe { height: 50vh; }
      .inbox__toggle { display: inline-flex; }
      .reader-panel.is-collapsed { display: none; }
      .story-list--grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
  <div class="reader-page">
  <div class="reader-app">
    <div class="reader-topbar">
      <div>
        <div class="reader-topbar__title">Reader workspace</div>
        <div class="muted" style="font-size: 12px;">NewsBlur-style browsing with publishing built in.</div>
      </div>
      <div class="reader-topbar__controls">
        <button type="button" class="inbox__toggle button-secondary" data-toggle-target="nav" style="display: none;">Show sites</button>
        <button type="button" class="inbox__toggle button-secondary" data-toggle-target="stories" style="display: none;">Show stories</button>
        {% set density_base = base_path ~ '/articles?' %}
        {% if active_feed_id %}
          {% set density_base = density_base ~ 'feed_id=' ~ active_feed_id ~ '&' %}
        {% endif %}
        {% if selected %}
          {% set density_base = density_base ~ 'selected=' ~ selected.id ~ '&mode=' ~ mode ~ '&layout=' ~ layout ~ '&' %}
        {% else %}
          {% set density_base = density_base ~ 'mode=' ~ mode ~ '&layout=' ~ layout ~ '&' %}
        {% endif %}
        <div class="toggle-group" aria-label="Density">
          <a class="toggle-chip toggle-chip--density-compact {% if density == 'compact' %}is-selected{% endif %}" href="{{ density_base }}density=compact" title="Compact view" aria-label="Compact view">
            <span class="toggle-chip__icon" aria-hidden="true"></span>
          </a>
          <a class="toggle-chip toggle-chip--density-comfortable {% if density == 'comfortable' %}is-selected{% endif %}" href="{{ density_base }}density=comfortable" title="Comfortable view" aria-label="Comfortable view">
            <span class="toggle-chip__icon" aria-hidden="true"></span>
          </a>
        </div>
        {% set layout_base = base_path ~ '/articles?' %}
        {% if active_feed_id %}
          {% set layout_base = layout_base ~ 'feed_id=' ~ active_feed_id ~ '&' %}
        {% endif %}
        {% if selected %}
          {% set layout_base = layout_base ~ 'selected=' ~ selected.id ~ '&mode=' ~ mode ~ '&density=' ~ density ~ '&' %}
        {% else %}
          {% set layout_base = layout_base ~ 'mode=' ~ mode ~ '&density=' ~ density ~ '&' %}
        {% endif %}
        <div class="toggle-group" aria-label="Layout">
          <a class="toggle-chip toggle-chip--layout-split {% if layout == 'split' %}is-selected{% endif %}" href="{{ layout_base }}layout=split" title="Split layout" aria-label="Split layout">
            <span class="toggle-chip__icon" aria-hidden="true"></span>
          </a>
          <a class="toggle-chip toggle-chip--layout-magazine {% if layout == 'magazine' %}is-selected{% endif %}" href="{{ layout_base }}layout=magazine" title="Magazine layout" aria-label="Magazine layout">
            <span class="toggle-chip__icon" aria-hidden="true"></span>
          </a>
          <a class="toggle-chip toggle-chip--layout-grid {% if layout == 'grid' %}is-selected{% endif %}" href="{{ layout_base }}layout=grid" title="Grid layout" aria-label="Grid layout">
            <span class="toggle-chip__icon" aria-hidden="true"><span></span><span></span><span></span><span></span></span>
          </a>
        </div>
      </div>
    </div>

    <div class="reader-shell">
      <div class="reader-panel reader-panel--nav">
        <div class="panel-kicker">Sites</div>
        <div class="site-item {% if not active_feed_id %}active{% endif %}">
          <a class="site-link" href="{{ base_path }}/articles?density={{ density }}&layout={{ layout }}">
            <span class="site-favicon" aria-hidden="true"></span>
            <div>
              <div class="site-title-row">
                <strong>All stories</strong>
                <span class="count-pill">{{ articles|length }}</span>
              </div>
              <div class="muted" style="font-size: 12px;">Global river across every active site.</div>
            </div>
          </a>
        </div>
        {% for feed in feeds %}
          <div class="site-item {% if active_feed_id == feed.id %}active{% endif %}">
            <a class="site-link" href="{{ base_path }}/articles?feed_id={{ feed.id }}&density={{ density }}&layout={{ layout }}" style="box-shadow: inset 3px 0 0 {{ feed.accent_color }};">
              {% if feed.favicon_url %}
                <img class="site-favicon" src="{{ feed.favicon_url }}" alt="" loading="lazy" />
              {% else %}
                <span class="site-favicon" aria-hidden="true"></span>
              {% endif %}
              <div>
                <div class="site-title-row">
                  <strong>{{ feed.name }}</strong>
                  <span class="count-pill">{{ feed.unread_count }}</span>
                </div>
                <div class="muted" style="font-size: 12px;">
                  {{ feed.article_count }} stories{% if not feed.is_active %} · paused{% endif %}
                </div>
              </div>
            </a>
          </div>
        {% endfor %}
      </div>

      <div class="reader-panel reader-panel--stories">
        <div class="story-toolbar">
          <div>
            <div class="panel-kicker">{{ river_label }}</div>
            <strong>{% if active_feed_id and selected %}{{ selected.feed_name }}{% elseif active_feed_id %}Selected site{% else %}All stories{% endif %}</strong>
          </div>
          <div class="actions-row">
            <form method="post" action="{{ base_path }}/articles/archive-all">
              <input type="hidden" name="_csrf" value="{{ csrf }}" />
              {% if active_feed_id %}
                <input type="hidden" name="feed_id" value="{{ active_feed_id }}" />
              {% endif %}
              <button type="submit" class="button-secondary">Archive all</button>
            </form>
          </div>
        </div>

        {% if articles|length == 0 %}
          <div class="empty-state muted">No stories in this stream yet.</div>
        {% else %}
          <div class="story-list {% if density == 'compact' %}story-list--compact{% endif %} {% if layout == 'grid' %}story-list--grid{% elseif layout == 'magazine' %}story-list--magazine{% endif %}">
            {% for article in articles %}
              {% set is_selected = selected and selected.id == article.id %}
              <div class="story-item {% if is_selected %}active{% endif %}" {% if is_selected %}style="border-color: {{ article.accent_color }}; box-shadow: 0 10px 24px rgba(11, 93, 30, 0.06);"{% endif %}>
                <a class="story-card-link" href="{{ base_path }}/articles?{% if active_feed_id %}feed_id={{ active_feed_id }}&{% endif %}selected={{ article.id }}&mode={{ mode }}&density={{ density }}&layout={{ layout }}">
                  <div class="story-thumb {% if density == 'compact' %}story-thumb--compact{% endif %}">
                    {% if article.thumbnail_url %}
                      <img src="{{ article.thumbnail_url }}" alt="" loading="lazy" />
                    {% else %}
                      {% if article.favicon_url %}
                        <img src="{{ article.favicon_url }}" alt="" loading="lazy" style="width: 24px; height: 24px; object-fit: contain;" />
                      {% else %}
                        Story
                      {% endif %}
                    {% endif %}
                  </div>
                  <div class="story-content">
                    <div class="story-title-row">
                      <strong>{{ article.title }}</strong>
                      {% if not article.is_read %}
                        <span class="count-pill">new</span>
                      {% endif %}
                    </div>
                    <div class="muted" style="font-size: 12px;">
                      {% if article.favicon_url %}
                        <img class="site-favicon" src="{{ article.favicon_url }}" alt="" loading="lazy" style="width: 14px; height: 14px; margin-right: 4px; vertical-align: -2px;" />
                      {% endif %}
                      {{ article.feed_name }} · {{ article.published_at ?: article.created_at }}
                    </div>
                    {% if density != 'compact' %}
                      <div class="story-summary">
                        {{ article.content_text|slice(0, 220) }}{% if article.content_text|length > 220 %}…{% endif %}
                      </div>
                    {% endif %}
                  </div>
                </a>
              </div>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="reader-panel reader-panel--main">
      <div class="reader-viewer">
        {% if selected %}
          {% if status == 'shared' %}
            <div class="card" style="margin-bottom: 12px;">
              <p class="muted">Article shared.</p>
            </div>
          {% elseif status == 'duplicate_ignored' %}
            <div class="card" style="margin-bottom: 12px;">
              <p class="muted">Duplicate submit ignored.</p>
            </div>
          {% elseif status == 'rate_limited' %}
            <div class="card" style="margin-bottom: 12px;">
              <p class="muted">Article scheduled (rate limit).</p>
            </div>
          {% elseif status == 'scheduled' %}
            <div class="card" style="margin-bottom: 12px;">
              <p class="muted">Article scheduled.</p>
            </div>
          {% elseif status == 'failed' %}
            <div class="card" style="margin-bottom: 12px;">
              <p class="muted">Share failed. Check account settings.</p>
            </div>
          {% endif %}
          {% if post_details %}
            <div class="card" style="margin-bottom: 12px;">
              <p class="muted">Per network:</p>
              <ul style="margin: 8px 0 0 16px;">
                {% for row in post_details %}
                  <li class="muted">
                    {{ row.platform }} — {{ row.status }}
                    {% if row.status == 'failed' and row.error %}
                      ({{ row.error }})
                    {% endif %}
                  </li>
                {% endfor %}
              </ul>
            </div>
          {% endif %}
          {% if error %}
            <div class="card" style="margin-bottom: 12px;">
              <p class="status-pill">Please add a comment, schedule time, and at least one account</p>
            </div>
          {% endif %}
          <div class="reader-stage">
            <div class="reader-stage__article">
              <div class="reader-meta-card">
                <div class="inbox__meta">
                  <div>
                    <strong>{{ selected.title }}</strong>
                    <div class="article-source">
                      {% if selected.favicon_url %}
                        <img class="site-favicon" src="{{ selected.favicon_url }}" alt="" loading="lazy" />
                      {% endif %}
                      <span class="source-dot" style="background: {{ selected.accent_color }};"></span>
                      <span>{{ selected.feed_name }}</span>
                      {% if selected.feed_host %}
                        <span>{{ selected.feed_host }}</span>
                      {% endif %}
                    </div>
                  </div>
                  <div class="actions-row">
                    {% if mode == 'reader' %}
                      <span class="muted">Reader</span>
                      <a href="{{ base_path }}/articles?{% if active_feed_id %}feed_id={{ active_feed_id }}&{% endif %}selected={{ selected.id }}&mode=original&density={{ density }}&layout={{ layout }}">Original</a>
                    {% else %}
                      <a href="{{ base_path }}/articles?{% if active_feed_id %}feed_id={{ active_feed_id }}&{% endif %}selected={{ selected.id }}&mode=reader&density={{ density }}&layout={{ layout }}">Reader</a>
                      <span class="muted">Original</span>
                    {% endif %}
                    <a href="{{ selected.url }}" target="_blank" rel="noopener">Open in new tab</a>
                    <form method="post" action="{{ base_path }}/articles/{{ selected.id }}/archive" class="inline-form">
                      <input type="hidden" name="_csrf" value="{{ csrf }}" />
                      <button type="submit" class="button-secondary">Archive</button>
                    </form>
                  </div>
                </div>
              </div>

              {% if mode == 'original' %}
                <iframe class="inbox__iframe" src="{{ selected.url }}" title="{{ selected.title }}"></iframe>
              {% else %}
                <iframe class="inbox__iframe" src="{{ base_path }}/articles/{{ selected.id }}/embed" title="{{ selected.title }}"></iframe>
              {% endif %}
            </div>

            <div class="reader-stage__compose">
              <div class="card">
                <div class="page-header" style="margin-bottom: 14px;">
                  <div>
                    <span class="eyebrow">Publish</span>
                    <strong>Queue this story</strong>
                  </div>
                  <span class="muted" style="font-size: 12px;">{{ selected.feed_name }}</span>
                </div>
                <form method="post" action="{{ base_path }}/posts" class="form-stack">
                  <input type="hidden" name="_csrf" value="{{ csrf }}" />
                  <input type="hidden" name="_submit_token" value="{{ submit_token }}" />
                  <input type="hidden" name="article_id" value="{{ selected.id }}" />
                  <input type="hidden" name="return_to" value="{{ base_path }}/articles?{% if active_feed_id %}feed_id={{ active_feed_id }}&{% endif %}selected={{ selected.id }}&mode={{ mode }}&density={{ density }}&layout={{ layout }}" />
                  <label>
                    Comment
                    <textarea id="article-comment" name="comment" rows="4" style="width: 100%;"></textarea>
                  </label>
                  <div class="muted" style="font-size: 12px;">
                    Length: <span id="article-comment-length">0</span>
                  </div>
                  <div style="margin-top: 6px; display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
                    <label>
                      Generate
                      <select id="article-generate-mode">
                        <option value="comment">Comment</option>
                        <option value="summary">Summary</option>
                        <option value="phrase">Impactful phrase</option>
                      </select>
                    </label>
                    <button type="button" data-generate-comment data-article-id="{{ selected.id }}">Generate</button>
                    <span class="muted" data-comment-status></span>
                  </div>
                  <label>
                    Schedule ({{ schedule_timezone }})
                    <input id="article-schedule" type="datetime-local" name="scheduled_at" value="{{ default_schedule_input }}" />
                  </label>
                  <fieldset>
                    <legend>Accounts</legend>
                    {% if accounts|length == 0 %}
                      <p class="muted">No active accounts yet.</p>
                    {% else %}
                      <div class="stack" style="gap: 10px;">
                      {% for account in accounts %}
                        <label class="checkbox-row">
                          <input type="checkbox" name="account_ids[]" value="{{ account.id }}" />
                          {{ account.platform }} · {{ account.display_name }} ({{ account.handle }})
                        </label>
                      {% endfor %}
                      </div>
                    {% endif %}
                  </fieldset>
                  <div class="actions-row">
                    <button type="submit" name="action" value="schedule">Schedule</button>
                    <button type="submit" name="action" value="now" class="button-secondary">Share now</button>
                  </div>
                </form>
              </div>
            </div>
          </div>
        {% else %}
          <div class="empty-state muted">
            Select an article to preview and schedule.
          </div>
        {% endif %}
      </div>
      </div>
    </div>
  </div>
  </div>

  <script>
    (function () {
      var toggles = document.querySelectorAll('.inbox__toggle');
      var panels = {
        nav: document.querySelector('.reader-panel--nav'),
        stories: document.querySelector('.reader-panel--stories')
      };

      function applyState() {
        toggles.forEach(function (toggle) {
          var target = toggle.getAttribute('data-toggle-target');
          var panel = target ? panels[target] : null;
          if (!panel) return;
          if (window.innerWidth <= 900) {
            var collapsed = panel.classList.contains('is-collapsed');
            toggle.style.display = 'inline-flex';
            toggle.textContent = collapsed
              ? 'Show ' + (target === 'nav' ? 'sites' : 'stories')
              : 'Hide ' + (target === 'nav' ? 'sites' : 'stories');
          } else {
            toggle.style.display = 'none';
            panel.classList.remove('is-collapsed');
          }
        });
      }

      toggles.forEach(function (toggle) {
        toggle.addEventListener('click', function () {
          var target = toggle.getAttribute('data-toggle-target');
          var panel = target ? panels[target] : null;
          if (!panel) return;
          panel.classList.toggle('is-collapsed');
          applyState();
        });
      });

      window.addEventListener('resize', applyState);
      applyState();
    })();

    (function () {
      var button = document.querySelector('[data-generate-comment]');
      if (!button) return;
      var status = document.querySelector('[data-comment-status]');
      var textarea = document.getElementById('article-comment');
      var csrf = '{{ csrf }}';
      var basePath = '{{ base_path }}';
      var modeSelect = document.getElementById('article-generate-mode');
      var lengthEl = document.getElementById('article-comment-length');

      button.addEventListener('click', function () {
        var articleId = button.getAttribute('data-article-id');
        if (!articleId || !textarea) return;
        button.disabled = true;
        if (status) status.textContent = 'Generating...';
        var body = new URLSearchParams();
        body.set('_csrf', csrf);
        if (modeSelect && modeSelect.value) {
          body.set('mode', modeSelect.value);
        }
        fetch(basePath + '/articles/' + articleId + '/comment', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: body.toString()
        })
          .then(function (res) { return res.text(); })
          .then(function (text) {
            textarea.value = text;
            if (lengthEl) lengthEl.textContent = String(text.length);
            if (status) status.textContent = '';
          })
          .catch(function () {
            if (status) status.textContent = 'Failed to generate.';
          })
          .finally(function () {
            button.disabled = false;
          });
      });

      if (textarea && lengthEl) {
        textarea.addEventListener('input', function () {
          lengthEl.textContent = String(textarea.value.length);
        });
      }
    })();
  </script>
{% endblock %}

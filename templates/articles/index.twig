{% extends "layout.twig" %}

{% block content %}
  <style>
    .reader-page {
      position: fixed;
      top: var(--app-header-height);
      right: 0;
      bottom: 0;
      left: 0;
      overflow: hidden;
    }
    .reader-app {
      background: rgba(255, 255, 255, 0.72);
      border: 0;
      border-radius: 0;
      box-shadow: 0 24px 48px rgba(11, 93, 30, 0.1);
      overflow: hidden;
      height: 100%;
      display: flex;
      flex-direction: column;
    }
    .reader-app button,
    .reader-app .button-secondary {
      border-radius: 8px;
      padding: 7px 10px;
      line-height: 1.1;
    }
    .reader-topbar {
      position: sticky;
      top: 0;
      z-index: 5;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      padding: 4px 8px;
      border-bottom: 1px solid var(--line-soft);
      background: rgba(247, 248, 243, 0.94);
    }
    .reader-topbar__title {
      font-size: 16px;
      letter-spacing: -0.02em;
      line-height: 1.1;
    }
    .reader-notice-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 10px 14px;
      border-top: 1px solid var(--line-soft);
      background: rgba(248, 249, 244, 0.94);
      color: var(--ink);
      font-size: 13px;
    }
    .reader-notice-bar ul {
      margin: 0;
      padding-left: 16px;
    }
    .reader-topbar__controls {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
    }
    .toggle-group {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 2px;
      border: 1px solid var(--border);
      border-radius: 10px;
      background: rgba(255, 255, 255, 0.88);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.72);
    }
    .toggle-chip {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      min-width: 34px;
      padding: 5px 8px;
      border: 1px solid transparent;
      border-radius: 8px;
      background: transparent;
      color: var(--muted);
      text-decoration: none;
      font-size: 12px;
      line-height: 1;
    }
    .toggle-chip:hover {
      background: rgba(90, 170, 149, 0.08);
      color: var(--ink);
    }
    .toggle-chip.is-selected {
      background: var(--accent);
      border-color: var(--accent);
      color: #fff;
      box-shadow: 0 6px 16px rgba(11, 93, 30, 0.16);
    }
    .toggle-chip__icon {
      width: 14px;
      height: 14px;
      display: inline-block;
      position: relative;
      flex: 0 0 auto;
    }
    .toggle-chip--density-compact .toggle-chip__icon::before,
    .toggle-chip--density-compact .toggle-chip__icon::after,
    .toggle-chip--density-comfortable .toggle-chip__icon::before,
    .toggle-chip--density-comfortable .toggle-chip__icon::after,
    .toggle-chip--layout-split .toggle-chip__icon::before,
    .toggle-chip--layout-split .toggle-chip__icon::after,
    .toggle-chip--layout-magazine .toggle-chip__icon::before,
    .toggle-chip--layout-magazine .toggle-chip__icon::after,
    .toggle-chip--layout-grid .toggle-chip__icon::before,
    .toggle-chip--layout-grid .toggle-chip__icon::after {
      content: "";
      position: absolute;
      background: currentColor;
      border-radius: 2px;
    }
    .toggle-chip--density-compact .toggle-chip__icon::before {
      inset: 1px 1px 8px 1px;
    }
    .toggle-chip--density-compact .toggle-chip__icon::after {
      inset: 9px 1px 1px 1px;
    }
    .toggle-chip--density-comfortable .toggle-chip__icon::before {
      inset: 1px 1px 10px 1px;
    }
    .toggle-chip--density-comfortable .toggle-chip__icon::after {
      inset: 11px 1px 1px 1px;
    }
    .toggle-chip--layout-split .toggle-chip__icon::before {
      left: 1px;
      top: 1px;
      bottom: 1px;
      width: 4px;
    }
    .toggle-chip--layout-split .toggle-chip__icon::after {
      right: 1px;
      top: 1px;
      bottom: 1px;
      width: 7px;
    }
    .toggle-chip--layout-magazine .toggle-chip__icon::before {
      left: 1px;
      top: 1px;
      bottom: 1px;
      width: 5px;
    }
    .toggle-chip--layout-magazine .toggle-chip__icon::after {
      right: 1px;
      top: 3px;
      bottom: 3px;
      width: 6px;
    }
    .toggle-chip--layout-grid .toggle-chip__icon {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: repeat(2, 1fr);
      gap: 2px;
    }
    .toggle-chip--layout-grid .toggle-chip__icon::before,
    .toggle-chip--layout-grid .toggle-chip__icon::after {
      display: none;
    }
    .toggle-chip--layout-grid .toggle-chip__icon span {
      display: block;
      background: currentColor;
      border-radius: 2px;
    }
    .reader-shell {
      display: grid;
      grid-template-columns: 260px 360px minmax(0, 1fr);
      gap: 0;
      align-items: stretch;
      height: 100%;
      min-height: 0;
      flex: 1 1 auto;
    }
    .reader-panel {
      min-height: 0;
    }
    .reader-panel--nav,
    .reader-panel--stories {
      height: 100%;
      max-height: none;
      overflow: auto;
      background: rgba(245, 245, 239, 0.82);
      scrollbar-width: thin;
      overscroll-behavior: contain;
    }
    .reader-panel--nav {
      border-right: 1px solid var(--line-soft);
      padding: 10px 8px 14px;
    }
    .reader-panel--stories {
      border-right: 1px solid var(--line-soft);
      padding: 10px 10px 14px;
      background: rgba(255, 255, 255, 0.92);
    }
    .reader-panel--main {
      background: rgba(255, 255, 255, 0.96);
      padding: 8px 10px 10px;
      min-width: 0;
      overflow: hidden;
      height: 100%;
      display: flex;
      flex-direction: column;
    }
    .reader-shell.is-nav-collapsed {
      grid-template-columns: 0 360px minmax(0, 1fr);
    }
    .reader-shell.is-stories-collapsed {
      grid-template-columns: 260px 0 minmax(0, 1fr);
    }
    .reader-shell.is-nav-collapsed.is-stories-collapsed {
      grid-template-columns: minmax(0, 1fr);
    }
    .reader-shell.is-nav-collapsed .reader-panel--nav,
    .reader-shell.is-stories-collapsed .reader-panel--stories {
      padding: 0;
      border-right: 0;
      overflow: hidden;
      max-height: 0;
    }
    .story-item,
    .site-item {
      padding: 8px 7px;
      border-bottom: 1px solid var(--line-soft);
    }
    .story-list--compact .story-item {
      padding: 6px 8px;
    }
    .story-list--compact .story-title-row {
      gap: 6px;
    }
    .story-list--compact .story-item strong {
      font-size: 14px;
      line-height: 1.35;
    }
    .story-list--compact .story-item .muted {
      font-size: 11px !important;
    }
    .story-item a,
    .site-item a {
      text-decoration: none;
      display: block;
    }
    .story-item.active,
    .site-item.active {
      background: var(--selection);
      border-radius: 10px;
    }
    .site-item {
      border-bottom: 0;
      margin-bottom: 3px;
    }
    .site-group + .site-group {
      margin-top: 16px;
    }
    .site-group__header {
      position: sticky;
      top: 0;
      z-index: 1;
      margin: 0 0 8px;
      padding: 6px 8px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
      background: rgba(245, 245, 239, 0.95);
      border-bottom: 1px solid var(--line-soft);
    }
    .site-link {
      display: grid !important;
      grid-template-columns: 20px minmax(0, 1fr);
      gap: 8px;
      align-items: start;
    }
    .site-favicon {
      width: 16px;
      height: 16px;
      border-radius: 4px;
      background: rgba(90, 170, 149, 0.14);
      border: 1px solid rgba(11, 93, 30, 0.08);
      object-fit: cover;
      margin-top: 1px;
    }
    .site-link strong {
      font-size: 13px;
      line-height: 1.2;
    }
    .site-stale-dot {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: #cc3d2b;
      box-shadow: 0 0 0 3px rgba(204, 61, 43, 0.14);
      display: inline-block;
      margin-left: 6px;
      vertical-align: middle;
    }
    .site-link .muted {
      font-size: 11px !important;
      line-height: 1.25;
    }
    .site-item.active {
      box-shadow: inset 3px 0 0 #84b316;
    }
    .story-item {
      border: 1px solid transparent;
      border-radius: 10px;
      margin-bottom: 6px;
      background: rgba(255, 255, 255, 0.78);
    }
    .story-item.active {
      border-color: rgba(132, 179, 22, 0.22);
      box-shadow: 0 10px 24px rgba(11, 93, 30, 0.06);
    }
    .story-list--grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }
    .story-list--grid .story-item {
      margin-bottom: 0;
      height: 100%;
    }
    .story-list--grid .story-card-link {
      grid-template-columns: 1fr;
    }
    .story-list--grid .story-thumb {
      width: 100%;
      aspect-ratio: 1.45;
    }
    .story-list--grid .story-summary {
      -webkit-line-clamp: 4;
    }
    .story-list--magazine .story-thumb {
      width: 124px;
      aspect-ratio: 0.78;
    }
    .story-list--magazine .story-card-link {
      grid-template-columns: 124px minmax(0, 1fr);
      gap: 14px;
    }
    .story-card-link {
      display: grid !important;
      grid-template-columns: 92px minmax(0, 1fr);
      gap: 10px;
      align-items: start;
    }
    .story-thumb {
      width: 92px;
      aspect-ratio: 0.72;
      border-radius: 8px;
      overflow: hidden;
      background:
        linear-gradient(160deg, rgba(247, 203, 21, 0.24), rgba(90, 170, 149, 0.18)),
        rgba(248, 249, 244, 0.96);
      border: 1px solid rgba(11, 93, 30, 0.08);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--muted);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .story-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .story-thumb--compact {
      width: 52px;
      border-radius: 8px;
    }
    .story-content {
      min-width: 0;
    }
    .story-summary {
      margin-top: 6px;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.4;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 3;
      overflow: hidden;
    }
    .story-list--compact .story-card-link {
      grid-template-columns: 52px minmax(0, 1fr);
      gap: 10px;
    }
    .article-source {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: 8px;
      font-size: 12px;
      color: var(--muted);
    }
    .source-dot {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      flex: 0 0 auto;
    }
    .reader-viewer {
      display: flex;
      flex-direction: column;
      gap: 16px;
      min-height: 0;
      min-width: 0;
      height: 100%;
    }
    .reader-stage {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 300px;
      gap: 0;
      align-items: stretch;
      height: 100%;
    }
    .reader-stage__article {
      min-width: 0;
      padding-right: 14px;
      min-height: 0;
      display: flex;
      flex-direction: column;
      height: 100%;
    }
    .reader-stage__compose {
      position: sticky;
      top: 0;
      border-left: 1px solid var(--line-soft);
      padding-left: 14px;
      align-self: start;
    }
    .inbox__iframe {
      width: 100%;
      height: auto;
      flex: 1 1 auto;
      min-height: 0;
      display: block;
      border: 1px solid var(--border);
      border-radius: 14px;
      background: var(--card-solid);
    }
    .reader-inline {
      flex: 1 1 auto;
      min-height: 0;
      overflow: auto;
      border: 1px solid var(--border);
      border-radius: 14px;
      background: #fffaf2;
      padding: 28px;
    }
    .reader-inline__body {
      max-width: 720px;
      margin: 0 auto;
      color: #1e1a16;
      font-family: ui-serif, Georgia, Cambria, "Times New Roman", Times, serif;
      line-height: 1.8;
    }
    .reader-inline__body p {
      margin: 0 0 18px;
    }
    .reader-inline__body h1,
    .reader-inline__body h2,
    .reader-inline__body h3 {
      line-height: 1.3;
      margin: 0 0 12px;
      color: #1e1a16;
    }
    .reader-inline__body img,
    .reader-inline__body video,
    .reader-inline__body iframe {
      max-width: 100%;
      height: auto;
    }
    .reader-inline__body pre,
    .reader-inline__body code {
      white-space: pre-wrap;
      word-break: break-word;
    }
    .panel-toolbar {
      display: flex;
      justify-content: space-between;
      align-items: end;
      gap: 12px;
      margin-bottom: 10px;
      flex-wrap: wrap;
    }
    .story-toolbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      margin-bottom: 10px;
      position: sticky;
      top: 0;
      z-index: 2;
      padding-bottom: 10px;
      background: rgba(255, 255, 255, 0.94);
      border-bottom: 1px solid var(--line-soft);
    }
    .inbox__meta {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
      flex-wrap: wrap;
    }
    .inbox__meta .actions-row {
      align-items: center;
    }
    .panel-kicker {
      margin-bottom: 10px;
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .panel-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      margin-bottom: 10px;
    }
    .panel-head .panel-kicker {
      margin-bottom: 0;
    }
    .column-heading {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 10px;
      margin-bottom: 10px;
    }
    .column-heading__title {
      margin: 0;
      font-size: 13px;
      line-height: 1.15;
      font-weight: 700;
      color: var(--ink);
    }
    .column-heading__meta {
      margin-top: 6px;
      font-size: 12px;
      color: var(--muted);
    }
    .site-title-row,
    .story-title-row {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: baseline;
    }
    .count-pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 28px;
      padding: 2px 8px;
      border-radius: 999px;
      background: rgba(90, 170, 149, 0.12);
      color: var(--muted);
      font-size: 12px;
    }
    .reader-meta-card {
      padding: 6px 4px 10px;
      border: 0;
      border-radius: 0;
      background: transparent;
      box-shadow: none;
    }
    .reader-stage__compose .card {
      padding: 6px 14px 12px;
      border: 0;
      border-radius: 0;
      background: transparent;
      box-shadow: none;
    }
    @media (max-width: 900px) {
      .reader-topbar {
        padding: 4px 6px;
      }
      .reader-page {
        position: static;
        inset: auto;
        overflow: visible;
      }
      .reader-app {
        border: 1px solid rgba(11, 93, 30, 0.1);
        border-radius: 14px;
      }
      .reader-page,
      .reader-app,
      .reader-shell,
      .reader-viewer {
        height: auto;
      }
      .reader-shell { grid-template-columns: 1fr; }
      .reader-panel--nav,
      .reader-panel--stories { height: auto; max-height: none; border-right: 0; padding-right: 0; }
      .reader-panel--main {
        padding: 14px 12px 18px;
        height: auto;
      }
      .reader-stage {
        grid-template-columns: 1fr;
        height: auto;
      }
      .reader-stage__compose {
        position: static;
        border-left: 0;
        padding-left: 0;
        margin-top: 14px;
      }
      .reader-stage__article {
        padding-right: 0;
      }
      .inbox__iframe { height: 50vh; }
      .inbox__toggle { display: inline-flex; }
      .reader-panel.is-collapsed { display: none; }
      .story-list--grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
  <div class="reader-page">
  <div class="reader-app">
    {% set notice_message = '' %}
    {% if status == 'shared' %}
      {% set notice_message = 'Article shared.' %}
    {% elseif status == 'duplicate_ignored' %}
      {% set notice_message = 'Duplicate submit ignored.' %}
    {% elseif status == 'rate_limited' %}
      {% set notice_message = 'Article scheduled because of rate limits.' %}
    {% elseif status == 'scheduled' %}
      {% set notice_message = 'Article scheduled.' %}
    {% elseif status == 'failed' %}
      {% set notice_message = 'Share failed. Check account settings.' %}
    {% elseif status == 'fetch_started' %}
      {% set notice_message = 'Feed refresh started in the background.' %}
    {% elseif status == 'fetch_complete' %}
      {% set notice_message = active_feed_id ? 'Feed refreshed.' : 'Feed refresh complete.' %}
    {% elseif status == 'fetch_checked' %}
      {% set notice_message = active_feed_id ? 'Feed checked. No new items were imported.' : 'Feed check complete. No new items were imported.' %}
    {% elseif status == 'fetch_failed' %}
      {% set notice_message = 'Could not start the feed refresh.' %}
    {% elseif error %}
      {% set notice_message = 'Please add a comment, schedule time, and at least one account.' %}
    {% endif %}
    <div class="reader-topbar">
      <div>
        <div class="reader-topbar__title">Reader</div>
      </div>
      <div class="reader-topbar__controls">
        <button type="button" class="inbox__toggle button-secondary" data-toggle-target="nav" style="display: none;">Show sites</button>
        <button type="button" class="inbox__toggle button-secondary" data-toggle-target="stories" style="display: none;">Show stories</button>
        <form method="post" action="{{ base_path }}/feeds/fetch-all" class="inline-form">
          <input type="hidden" name="_csrf" value="{{ csrf }}" />
          <input type="hidden" name="return_to" value="{{ current_reader_url }}" />
          <button type="submit" class="button-secondary">Fetch all</button>
        </form>
        {% if active_feed_id %}
          <form method="post" action="{{ base_path }}/feeds/{{ active_feed_id }}/fetch" class="inline-form">
            <input type="hidden" name="_csrf" value="{{ csrf }}" />
            <input type="hidden" name="return_to" value="{{ current_reader_url }}" />
            <button type="submit" class="button-secondary">Refresh feed</button>
          </form>
        {% endif %}
        {% set density_base = base_path ~ '/articles?' %}
        {% if active_feed_id %}
          {% set density_base = density_base ~ 'feed_id=' ~ active_feed_id ~ '&' %}
        {% endif %}
        {% if selected %}
          {% set density_base = density_base ~ 'selected=' ~ selected.id ~ '&mode=' ~ mode ~ '&layout=' ~ layout ~ '&' %}
        {% else %}
          {% set density_base = density_base ~ 'mode=' ~ mode ~ '&layout=' ~ layout ~ '&' %}
        {% endif %}
        <div class="toggle-group" aria-label="Density">
          <a class="toggle-chip toggle-chip--density-compact {% if density == 'compact' %}is-selected{% endif %}" href="{{ density_base }}density=compact" title="Compact view" aria-label="Compact view">
            <span class="toggle-chip__icon" aria-hidden="true"></span>
          </a>
          <a class="toggle-chip toggle-chip--density-comfortable {% if density == 'comfortable' %}is-selected{% endif %}" href="{{ density_base }}density=comfortable" title="Comfortable view" aria-label="Comfortable view">
            <span class="toggle-chip__icon" aria-hidden="true"></span>
          </a>
        </div>
        {% set layout_base = base_path ~ '/articles?' %}
        {% if active_feed_id %}
          {% set layout_base = layout_base ~ 'feed_id=' ~ active_feed_id ~ '&' %}
        {% endif %}
        {% if selected %}
          {% set layout_base = layout_base ~ 'selected=' ~ selected.id ~ '&mode=' ~ mode ~ '&density=' ~ density ~ '&' %}
        {% else %}
          {% set layout_base = layout_base ~ 'mode=' ~ mode ~ '&density=' ~ density ~ '&' %}
        {% endif %}
        <div class="toggle-group" aria-label="Layout">
          <a class="toggle-chip toggle-chip--layout-split {% if layout == 'split' %}is-selected{% endif %}" href="{{ layout_base }}layout=split" title="Split layout" aria-label="Split layout">
            <span class="toggle-chip__icon" aria-hidden="true"></span>
          </a>
          <a class="toggle-chip toggle-chip--layout-magazine {% if layout == 'magazine' %}is-selected{% endif %}" href="{{ layout_base }}layout=magazine" title="Magazine layout" aria-label="Magazine layout">
            <span class="toggle-chip__icon" aria-hidden="true"></span>
          </a>
          <a class="toggle-chip toggle-chip--layout-grid {% if layout == 'grid' %}is-selected{% endif %}" href="{{ layout_base }}layout=grid" title="Grid layout" aria-label="Grid layout">
            <span class="toggle-chip__icon" aria-hidden="true"><span></span><span></span><span></span><span></span></span>
          </a>
        </div>
      </div>
    </div>

    <div class="reader-shell" data-reader-shell>
      <div class="reader-panel reader-panel--nav">
        <div class="panel-head">
          <div class="panel-kicker">Sites</div>
        </div>
        <div class="site-group">
          <div class="site-item {% if not active_feed_id %}active{% endif %}">
            <a class="site-link" data-site-link href="{{ base_path }}/articles?{% if selected %}selected={{ selected.id }}&{% endif %}mode={{ mode }}&density={{ density }}&layout={{ layout }}">
              <span class="site-favicon" aria-hidden="true"></span>
              <div>
                <div class="site-title-row">
                  <strong>All stories</strong>
                  <span class="count-pill">{{ articles|length }}</span>
                </div>
                <div class="muted" style="font-size: 12px;">Global river across every active site.</div>
              </div>
            </a>
          </div>
        </div>
        {% set current_folder = null %}
        {% for feed in feeds %}
          {% set folder_label = feed.folder_name ?: 'Unfiled' %}
          {% if folder_label != current_folder %}
            {% if not loop.first %}</div>{% endif %}
            <div class="site-group">
              <div class="site-group__header">{{ folder_label }}</div>
            {% set current_folder = folder_label %}
          {% endif %}
          <div class="site-item {% if active_feed_id == feed.id %}active{% endif %}">
            <a class="site-link" data-site-link href="{{ base_path }}/articles?feed_id={{ feed.id }}{% if selected and selected.feed_id == feed.id %}&selected={{ selected.id }}{% endif %}&mode={{ mode }}&density={{ density }}&layout={{ layout }}" style="box-shadow: inset 3px 0 0 {{ feed.accent_color }};">
              {% if feed.favicon_url %}
                <img class="site-favicon" src="{{ feed.favicon_url }}" alt="" loading="lazy" />
              {% else %}
                <span class="site-favicon" aria-hidden="true"></span>
              {% endif %}
              <div>
                <div class="site-title-row">
                  <strong>
                    {{ feed.name }}
                    {% if feed.is_stale %}
                      <span class="site-stale-dot" title="This feed has not been fetched in more than 6 months." aria-label="Stale feed"></span>
                    {% endif %}
                  </strong>
                  <span class="count-pill">{{ feed.unread_count }}</span>
                </div>
                {% if not feed.is_active %}
                  <div class="muted" style="font-size: 12px;">Paused</div>
                {% endif %}
              </div>
            </a>
          </div>
          {% if loop.last %}</div>{% endif %}
        {% endfor %}
      </div>

      <div class="reader-panel reader-panel--stories">
        <div class="story-toolbar">
          <div>
            {% if active_feed_id and selected %}
              <div class="panel-kicker">{{ selected.feed_name }}</div>
            {% elseif active_feed_id %}
              <div class="panel-kicker">Selected site</div>
            {% else %}
              <div class="panel-kicker">All stories</div>
              <strong>All stories</strong>
            {% endif %}
          </div>
          <div class="actions-row">
            <form method="post" action="{{ base_path }}/articles/archive-all">
              <input type="hidden" name="_csrf" value="{{ csrf }}" />
              {% if active_feed_id %}
                <input type="hidden" name="feed_id" value="{{ active_feed_id }}" />
              {% endif %}
              <button type="submit" class="button-secondary">Archive all</button>
            </form>
            {% if active_feed_id %}
              <form method="post" action="{{ base_path }}/feeds/{{ active_feed_id }}/fetch" class="inline-form">
                <input type="hidden" name="_csrf" value="{{ csrf }}" />
                <input type="hidden" name="return_to" value="{{ current_reader_url }}" />
                <button type="submit" class="button-secondary">Refresh feed</button>
              </form>
            {% endif %}
          </div>
        </div>

        {% if articles|length == 0 %}
          <div class="empty-state muted">No stories in this stream yet.</div>
        {% else %}
          <div class="story-list {% if density == 'compact' %}story-list--compact{% endif %} {% if layout == 'grid' %}story-list--grid{% elseif layout == 'magazine' %}story-list--magazine{% endif %}">
            {% for article in articles %}
              {% set is_selected = selected and selected.id == article.id %}
              <div class="story-item {% if is_selected %}active{% endif %}" data-story-item data-article-id="{{ article.id }}" data-accent-color="{{ article.accent_color }}" {% if is_selected %}style="border-color: {{ article.accent_color }}; box-shadow: 0 10px 24px rgba(11, 93, 30, 0.06);"{% endif %}>
                <a class="story-card-link" data-story-link data-article-id="{{ article.id }}" href="{{ base_path }}/articles?{% if active_feed_id %}feed_id={{ active_feed_id }}&{% endif %}selected={{ article.id }}&mode={{ mode }}&density={{ density }}&layout={{ layout }}">
                  <div class="story-thumb {% if density == 'compact' %}story-thumb--compact{% endif %}">
                    {% if article.thumbnail_url %}
                      <img src="{{ article.thumbnail_url }}" alt="" loading="lazy" />
                    {% else %}
                      {% if article.favicon_url %}
                        <img src="{{ article.favicon_url }}" alt="" loading="lazy" style="width: 24px; height: 24px; object-fit: contain;" />
                      {% else %}
                        Story
                      {% endif %}
                    {% endif %}
                  </div>
                  <div class="story-content">
                    <div class="story-title-row">
                      <strong>{{ article.title }}</strong>
                      {% if not article.is_read %}
                        <span class="count-pill">new</span>
                      {% endif %}
                    </div>
                    <div class="muted" style="font-size: 12px;">
                      {% if article.favicon_url %}
                        <img class="site-favicon" src="{{ article.favicon_url }}" alt="" loading="lazy" style="width: 14px; height: 14px; margin-right: 4px; vertical-align: -2px;" />
                      {% endif %}
                      {{ article.feed_name }} · {{ article.published_at ?: article.created_at }}
                    </div>
                    {% if density != 'compact' %}
                      <div class="story-summary">
                        {{ article.content_text|slice(0, 220) }}{% if article.content_text|length > 220 %}…{% endif %}
                      </div>
                    {% endif %}
                  </div>
                </a>
              </div>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="reader-panel reader-panel--main" id="reader-main" data-base-path="{{ base_path }}">
      <div class="reader-viewer">
        {% if selected %}
          <div class="reader-stage">
            <div class="reader-stage__article">
              <div class="reader-meta-card">
                <div class="column-heading">
                  <div>
                    <h2 class="column-heading__title" data-reader-title>{{ selected.title }}</h2>
                    <div class="article-source">
                      {% if selected.favicon_url %}
                        <img class="site-favicon" data-reader-favicon src="{{ selected.favicon_url }}" alt="" loading="lazy" />
                      {% else %}
                        <img class="site-favicon" data-reader-favicon src="" alt="" loading="lazy" style="display:none;" />
                      {% endif %}
                      <span class="source-dot" data-reader-accent style="background: {{ selected.accent_color }};"></span>
                      <span data-reader-feed-name>{{ selected.feed_name }}</span>
                      {% if selected.feed_host %}
                        <span data-reader-feed-host>{{ selected.feed_host }}</span>
                      {% else %}
                        <span data-reader-feed-host></span>
                      {% endif %}
                    </div>
                  </div>
                </div>
                <div class="inbox__meta">
                  <div class="actions-row">
                    {% if mode == 'reader' %}
                      <span class="muted">Reader</span>
                      <a href="{{ base_path }}/articles?{% if active_feed_id %}feed_id={{ active_feed_id }}&{% endif %}selected={{ selected.id }}&mode=original&density={{ density }}&layout={{ layout }}" data-reader-toggle-link>Original</a>
                    {% else %}
                      <a href="{{ base_path }}/articles?{% if active_feed_id %}feed_id={{ active_feed_id }}&{% endif %}selected={{ selected.id }}&mode=reader&density={{ density }}&layout={{ layout }}" data-reader-toggle-link>Reader</a>
                      <span class="muted">Original</span>
                    {% endif %}
                    <a href="{{ selected.url }}" target="_blank" rel="noopener" data-reader-open-link>Open in new tab</a>
                    <form method="post" action="{{ base_path }}/articles/{{ selected.id }}/archive" class="inline-form" data-reader-archive-form>
                      <input type="hidden" name="_csrf" value="{{ csrf }}" />
                      <button type="submit" class="button-secondary">Archive</button>
                    </form>
                  </div>
                </div>
              </div>

              <div data-reader-original-shell {% if mode != 'original' %}style="display: none;"{% endif %}>
                {% if mode == 'original' %}
                  <iframe class="inbox__iframe" data-reader-iframe src="{{ selected.url }}" title="{{ selected.title }}"></iframe>
                {% endif %}
              </div>
              <div class="reader-inline" data-reader-inline {% if mode == 'original' %}style="display: none;"{% endif %}>
                <div class="reader-inline__body" data-reader-inline-body>{{ selected.reader_html|default('')|raw }}</div>
              </div>
            </div>

            <div class="reader-stage__compose">
              <div class="card">
                <div class="column-heading">
                  <div>
                    <span class="eyebrow">Publish</span>
                    <h2 class="column-heading__title" style="margin-top: 2px;" data-publish-title>{{ selected.title }}</h2>
                  </div>
                </div>
                <form method="post" action="{{ base_path }}/posts" class="form-stack">
                  <input type="hidden" name="_csrf" value="{{ csrf }}" />
                  <input type="hidden" name="_submit_token" value="{{ submit_token }}" />
                  <input type="hidden" name="article_id" value="{{ selected.id }}" data-publish-article-id />
                  <input type="hidden" name="return_to" value="{{ base_path }}/articles?{% if active_feed_id %}feed_id={{ active_feed_id }}&{% endif %}selected={{ selected.id }}&mode={{ mode }}&density={{ density }}&layout={{ layout }}" data-publish-return-to />
                  <label>
                    Comment
                    <textarea id="article-comment" name="comment" rows="4" style="width: 100%;"></textarea>
                  </label>
                  <div class="muted" style="font-size: 12px;">
                    Length: <span id="article-comment-length">0</span>
                  </div>
                  <div style="margin-top: 6px; display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
                    <label>
                      Generate
                      <select id="article-generate-mode">
                        <option value="comment">Comment</option>
                        <option value="summary">Summary</option>
                        <option value="phrase">Impactful phrase</option>
                      </select>
                    </label>
                    <button type="button" data-generate-comment data-article-id="{{ selected.id }}">Generate</button>
                    <span class="muted" data-comment-status></span>
                  </div>
                  <label>
                    Schedule ({{ schedule_timezone }})
                    <input id="article-schedule" type="datetime-local" name="scheduled_at" value="{{ default_schedule_input }}" />
                  </label>
                  <fieldset>
                    <legend>Accounts</legend>
                    {% if accounts|length == 0 %}
                      <p class="muted">No active accounts yet.</p>
                    {% else %}
                      <div class="stack" style="gap: 10px;">
                      {% for account in accounts %}
                        <label class="checkbox-row">
                          <input type="checkbox" name="account_ids[]" value="{{ account.id }}" />
                          {{ account.platform }} · {{ account.display_name }} ({{ account.handle }})
                        </label>
                      {% endfor %}
                      </div>
                    {% endif %}
                  </fieldset>
                  <div class="actions-row">
                    <button type="submit" name="action" value="schedule">Schedule</button>
                    <button type="submit" name="action" value="now" class="button-secondary">Share now</button>
                  </div>
                </form>
              </div>
            </div>
          </div>
        {% else %}
          <div class="empty-state muted">
            Select an article to preview and schedule.
          </div>
        {% endif %}
      </div>
      </div>
    </div>
    {% if notice_message or post_details %}
      <div class="reader-notice-bar">
        <div>
          {% if notice_message %}
            {{ notice_message }}
          {% else %}
            Update available.
          {% endif %}
        </div>
        {% if post_details %}
          <ul>
            {% for row in post_details %}
              <li>
                {{ row.platform }} — {{ row.status }}{% if row.status == 'failed' and row.error %} ({{ row.error }}){% endif %}
              </li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>
    {% endif %}
  </div>
  </div>

  <script>
    (function () {
      var storagePrefix = 'echotree.reader.';
      var storiesPanel = document.querySelector('.reader-panel--stories');
      var navPanel = document.querySelector('.reader-panel--nav');
      var activeFeedId = {{ active_feed_id ?: 'null' }};
      var activeStoryId = {{ selected ? selected.id : 'null' }};
      var stateKey = storagePrefix + 'scroll.' + (activeFeedId || 'all');

      function restoreScroll(panel, key) {
        if (!panel) return false;
        var value = window.sessionStorage.getItem(stateKey + '.' + key);
        if (value === null) return false;
        panel.scrollTop = parseInt(value, 10) || 0;
        return true;
      }

      function persistScroll(panel, key) {
        if (!panel) return;
        panel.addEventListener('scroll', function () {
          window.sessionStorage.setItem(stateKey + '.' + key, String(panel.scrollTop));
        }, { passive: true });
      }

      persistScroll(navPanel, 'nav');
      persistScroll(storiesPanel, 'stories');

      var restoredNav = restoreScroll(navPanel, 'nav');
      var restoredStories = restoreScroll(storiesPanel, 'stories');

      if (!restoredNav) {
        var activeSite = document.querySelector('.site-item.active');
        if (navPanel && activeSite) {
          window.requestAnimationFrame(function () {
            var panelRect = navPanel.getBoundingClientRect();
            var itemRect = activeSite.getBoundingClientRect();
            if (itemRect.top < panelRect.top || itemRect.bottom > panelRect.bottom) {
              activeSite.scrollIntoView({ block: 'nearest', inline: 'nearest' });
            }
          });
        }
      }

      if (!restoredStories) {
        var activeStory = document.querySelector('.story-item.active');
        if (storiesPanel && activeStory) {
          window.requestAnimationFrame(function () {
            var panelRect = storiesPanel.getBoundingClientRect();
            var itemRect = activeStory.getBoundingClientRect();
            if (itemRect.top < panelRect.top || itemRect.bottom > panelRect.bottom) {
              activeStory.scrollIntoView({ block: 'nearest', inline: 'nearest' });
            }
          });
        }
      }

      if (activeFeedId !== null) {
        window.sessionStorage.setItem(storagePrefix + 'activeFeed', String(activeFeedId));
      }
      if (activeStoryId !== null) {
        window.sessionStorage.setItem(storagePrefix + 'activeStory', String(activeStoryId));
      }
    })();

    (function () {
      var toggles = document.querySelectorAll('.inbox__toggle');
      var shell = document.querySelector('[data-reader-shell]');
      var panels = {
        nav: document.querySelector('.reader-panel--nav'),
        stories: document.querySelector('.reader-panel--stories')
      };

      function applyState() {
        toggles.forEach(function (toggle) {
          var target = toggle.getAttribute('data-toggle-target');
          var panel = target ? panels[target] : null;
          if (!panel) return;
          var collapsed = window.innerWidth <= 900
            ? panel.classList.contains('is-collapsed')
            : shell && shell.classList.contains(target === 'nav' ? 'is-nav-collapsed' : 'is-stories-collapsed');
          toggle.style.display = 'inline-flex';
          toggle.textContent = collapsed
            ? 'Show ' + (target === 'nav' ? 'sites' : 'stories')
            : 'Hide ' + (target === 'nav' ? 'sites' : 'stories');
          if (window.innerWidth > 900) {
            panel.classList.remove('is-collapsed');
          }
        });
      }

      toggles.forEach(function (toggle) {
        toggle.addEventListener('click', function () {
          var target = toggle.getAttribute('data-toggle-target');
          var panel = target ? panels[target] : null;
          if (!panel) return;
          if (window.innerWidth <= 900) {
            panel.classList.toggle('is-collapsed');
          } else if (shell) {
            var collapsedClass = target === 'nav' ? 'is-nav-collapsed' : 'is-stories-collapsed';
            shell.classList.toggle(collapsedClass);
          }
          applyState();
        });
      });

      window.addEventListener('resize', applyState);
      applyState();
    })();

    (function () {
      var mainPanel = document.getElementById('reader-main');
      var hasSelected = {{ selected ? 'true' : 'false' }};
      if (!mainPanel || !hasSelected) return;
      if (window.innerWidth > 900) return;

      var navigationType = '';
      try {
        var entries = window.performance && window.performance.getEntriesByType ? window.performance.getEntriesByType('navigation') : [];
        navigationType = entries && entries[0] ? entries[0].type : '';
      } catch (error) {
        navigationType = '';
      }
      if (navigationType === 'reload' || navigationType === 'back_forward') return;

      window.requestAnimationFrame(function () {
        mainPanel.scrollIntoView({ block: 'start', behavior: 'auto' });
      });
    })();

    (function () {
      var storyLinks = Array.prototype.slice.call(document.querySelectorAll('[data-story-link]'));
      if (!storyLinks.length) return;

      var selectedFeedId = {{ active_feed_id ?: 'null' }};
      var mode = '{{ mode }}';
      var density = '{{ density }}';
      var layout = '{{ layout }}';
      var basePath = '{{ base_path }}';
      var readerTitle = document.querySelector('[data-reader-title]');
      var readerFavicon = document.querySelector('[data-reader-favicon]');
      var readerAccent = document.querySelector('[data-reader-accent]');
      var readerFeedName = document.querySelector('[data-reader-feed-name]');
      var readerFeedHost = document.querySelector('[data-reader-feed-host]');
      var readerToggleLink = document.querySelector('[data-reader-toggle-link]');
      var readerOpenLink = document.querySelector('[data-reader-open-link]');
      var readerArchiveForm = document.querySelector('[data-reader-archive-form]');
      var readerOriginalShell = document.querySelector('[data-reader-original-shell]');
      var readerIframe = document.querySelector('[data-reader-iframe]');
      var readerInline = document.querySelector('[data-reader-inline]');
      var readerInlineBody = document.querySelector('[data-reader-inline-body]');
      var publishTitle = document.querySelector('[data-publish-title]');
      var publishArticleId = document.querySelector('[data-publish-article-id]');
      var publishReturnTo = document.querySelector('[data-publish-return-to]');
      var generateButton = document.querySelector('[data-generate-comment]');
      var commentTextarea = document.getElementById('article-comment');
      var commentLength = document.getElementById('article-comment-length');
      var storyItems = Array.prototype.slice.call(document.querySelectorAll('[data-story-item]'));
      var requestId = 0;

      function updateActiveStory(articleId) {
        storyItems.forEach(function (item) {
          var isActive = String(articleId) === item.getAttribute('data-article-id');
          item.classList.toggle('active', isActive);
          if (isActive) {
            var accent = item.getAttribute('data-accent-color') || '#84b316';
            item.style.borderColor = accent;
            item.style.boxShadow = '0 10px 24px rgba(11, 93, 30, 0.06)';
          } else {
            item.style.borderColor = '';
            item.style.boxShadow = '';
          }
        });
      }

      function ensureReaderIframe(title) {
        if (!readerOriginalShell) return null;
        var iframe = readerOriginalShell.querySelector('[data-reader-iframe]');
        if (!iframe) {
          iframe = document.createElement('iframe');
          iframe.className = 'inbox__iframe';
          iframe.setAttribute('data-reader-iframe', '');
          readerOriginalShell.appendChild(iframe);
        }
        iframe.title = title || '';
        return iframe;
      }

      function applyArticle(article, href, replaceHistory) {
        if (!article) return;
        if (readerTitle) readerTitle.textContent = article.title;
        if (publishTitle) publishTitle.textContent = article.title;
        if (readerFeedName) readerFeedName.textContent = article.feed_name || '';
        if (readerFeedHost) readerFeedHost.textContent = article.feed_host || '';
        if (readerAccent) readerAccent.style.background = article.accent_color || '#84b316';
        if (readerFavicon) {
          if (article.favicon_url) {
            readerFavicon.src = article.favicon_url;
            readerFavicon.style.display = '';
          } else {
            readerFavicon.removeAttribute('src');
            readerFavicon.style.display = 'none';
          }
        }
        if (readerToggleLink) readerToggleLink.href = article.original_toggle_url;
        if (readerOpenLink) readerOpenLink.href = article.url;
        if (readerArchiveForm) readerArchiveForm.action = article.archive_url;
        if (readerOriginalShell && readerInline && readerInlineBody) {
          if (article.mode === 'original') {
            var activeIframe = ensureReaderIframe(article.title);
            readerOriginalShell.style.display = '';
            readerInline.style.display = 'none';
            if (activeIframe) {
              activeIframe.src = article.url;
            }
          } else {
            readerInline.style.display = '';
            readerOriginalShell.style.display = 'none';
            readerInlineBody.innerHTML = article.reader_html || '';
          }
        }
        if (publishArticleId) publishArticleId.value = String(article.id);
        if (publishReturnTo) publishReturnTo.value = article.return_to;
        if (generateButton) generateButton.setAttribute('data-article-id', String(article.id));
        if (commentTextarea) commentTextarea.value = '';
        if (commentLength) commentLength.textContent = '0';

        updateActiveStory(article.id);

        if (href && window.history) {
          var method = replaceHistory ? 'replaceState' : 'pushState';
          if (typeof window.history[method] === 'function') {
            window.history[method]({ articleId: article.id }, '', href);
          }
        }
      }

      function fetchAndApplyStory(link, replaceHistory) {
        if (!link) return Promise.resolve();
        var articleId = parseInt(link.getAttribute('data-article-id') || '0', 10);
        if (!articleId) {
          window.location.href = link.href;
          return Promise.resolve();
        }

        requestId += 1;
        var currentRequestId = requestId;
        updateActiveStory(articleId);

        var params = new URLSearchParams();
        params.set('selected', String(articleId));
        params.set('mode', mode);
        params.set('density', density);
        params.set('layout', layout);
        if (selectedFeedId) {
          params.set('feed_id', String(selectedFeedId));
        }

        return fetch(basePath + '/articles/selected?' + params.toString(), {
          headers: { 'Accept': 'application/json' }
        })
          .then(function (res) {
            if (!res.ok) throw new Error('article_fetch_failed');
            return res.json();
          })
          .then(function (payload) {
            if (currentRequestId !== requestId) return;
            if (!payload || !payload.ok || !payload.article) throw new Error('article_fetch_failed');
            applyArticle(payload.article, link.href, replaceHistory);
          })
          .catch(function () {
            window.location.href = link.href;
          });
      }

      function isTypingTarget(node) {
        if (!node) return false;
        var tag = (node.tagName || '').toLowerCase();
        return tag === 'input' || tag === 'textarea' || tag === 'select' || node.isContentEditable;
      }

      storyLinks.forEach(function (link) {
        link.addEventListener('click', function (event) {
          if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey || event.button !== 0) {
            return;
          }
          event.preventDefault();
          fetchAndApplyStory(link, false);
        });
      });

      document.addEventListener('keydown', function (event) {
        if (event.defaultPrevented || isTypingTarget(event.target)) return;
        if (event.key !== 'ArrowDown' && event.key !== 'ArrowUp') return;

        var currentIndex = -1;
        storyLinks.forEach(function (link, index) {
          if (link.closest('.story-item') && link.closest('.story-item').classList.contains('active')) {
            currentIndex = index;
          }
        });
        if (currentIndex === -1) return;

        var nextIndex = event.key === 'ArrowDown' ? currentIndex + 1 : currentIndex - 1;
        if (nextIndex < 0 || nextIndex >= storyLinks.length) return;

        event.preventDefault();
        fetchAndApplyStory(storyLinks[nextIndex], false);
      });

      window.addEventListener('popstate', function () {
        var currentUrl = new URL(window.location.href);
        var selected = parseInt(currentUrl.searchParams.get('selected') || '0', 10);
        if (!selected) return;

        var matchingLink = storyLinks.find(function (link) {
          return String(selected) === link.getAttribute('data-article-id');
        });

        if (matchingLink) {
          fetchAndApplyStory(matchingLink, true);
        } else {
          window.location.reload();
        }
      });

      if (readerInlineBody) {
        readerInlineBody.addEventListener('click', function (event) {
          if (event.defaultPrevented || event.button !== 0 || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) {
            return;
          }

          var link = event.target && event.target.closest ? event.target.closest('a[href]') : null;
          if (!link) return;

          var href = link.getAttribute('href') || '';
          if (!/^https?:\/\//i.test(href)) return;

          event.preventDefault();

          var params = new URLSearchParams();
          params.set('mode', mode);
          params.set('density', density);
          params.set('layout', layout);

          fetch(basePath + '/articles/follow?url=' + encodeURIComponent(href) + '&' + params.toString() + '&format=json', {
            headers: { 'Accept': 'application/json' }
          })
            .then(function (res) {
              if (!res.ok) throw new Error('follow_failed');
              return res.json();
            })
            .then(function (payload) {
              if (!payload || !payload.ok || !payload.article) throw new Error('follow_failed');
              applyArticle(payload.article, payload.article.return_to, false);
            })
            .catch(function () {
              window.location.href = basePath + '/articles/follow?url=' + encodeURIComponent(href) + '&' + params.toString();
            });
        });
      }
    })();

    (function () {
      var mainPanel = document.getElementById('reader-main');
      if (!mainPanel) return;

      var readerTitle = document.querySelector('[data-reader-title]');
      var readerFavicon = document.querySelector('[data-reader-favicon]');
      var readerAccent = document.querySelector('[data-reader-accent]');
      var readerFeedName = document.querySelector('[data-reader-feed-name]');
      var readerFeedHost = document.querySelector('[data-reader-feed-host]');
      var readerToggleLink = document.querySelector('[data-reader-toggle-link]');
      var readerOpenLink = document.querySelector('[data-reader-open-link]');
      var readerArchiveForm = document.querySelector('[data-reader-archive-form]');
      var readerOriginalShell = document.querySelector('[data-reader-original-shell]');
      var readerIframe = document.querySelector('[data-reader-iframe]');
      var readerInline = document.querySelector('[data-reader-inline]');
      var readerInlineBody = document.querySelector('[data-reader-inline-body]');
      var publishTitle = document.querySelector('[data-publish-title]');
      var publishArticleId = document.querySelector('[data-publish-article-id]');
      var publishReturnTo = document.querySelector('[data-publish-return-to]');
      var generateButton = document.querySelector('[data-generate-comment]');
      var commentTextarea = document.getElementById('article-comment');
      var commentLength = document.getElementById('article-comment-length');

      window.addEventListener('message', function (event) {
        var data = event.data || {};
        if (data.type !== 'echotree-follow-link' || !data.url || !data.followBase || !data.followParams) return;

        fetch(data.followBase + 'url=' + encodeURIComponent(data.url) + '&' + data.followParams + '&format=json', {
          headers: { 'Accept': 'application/json' }
        })
          .then(function (res) {
            if (!res.ok) throw new Error('follow_failed');
            return res.json();
          })
          .then(function (payload) {
            if (!payload || !payload.ok || !payload.article) throw new Error('follow_failed');
            var article = payload.article;
            if (readerTitle) readerTitle.textContent = article.title;
            if (publishTitle) publishTitle.textContent = article.title;
            if (readerFeedName) readerFeedName.textContent = article.feed_name || '';
            if (readerFeedHost) readerFeedHost.textContent = article.feed_host || '';
            if (readerAccent) readerAccent.style.background = article.accent_color || '#84b316';
            if (readerFavicon) {
              if (article.favicon_url) {
                readerFavicon.src = article.favicon_url;
                readerFavicon.style.display = '';
              } else {
                readerFavicon.style.display = 'none';
              }
            }
            if (readerToggleLink) readerToggleLink.href = article.original_toggle_url;
            if (readerOpenLink) readerOpenLink.href = article.url;
            if (readerArchiveForm) readerArchiveForm.action = article.archive_url;
            if (readerOriginalShell && readerInline && readerInlineBody) {
              if (article.mode === 'original') {
                var activeIframe = readerOriginalShell.querySelector('[data-reader-iframe]');
                if (!activeIframe) {
                  activeIframe = document.createElement('iframe');
                  activeIframe.className = 'inbox__iframe';
                  activeIframe.setAttribute('data-reader-iframe', '');
                  readerOriginalShell.appendChild(activeIframe);
                }
                readerOriginalShell.style.display = '';
                readerInline.style.display = 'none';
                activeIframe.src = article.url;
                activeIframe.title = article.title;
              } else {
                readerInline.style.display = '';
                readerOriginalShell.style.display = 'none';
                readerInlineBody.innerHTML = article.reader_html || '';
              }
            }
            if (publishArticleId) publishArticleId.value = String(article.id);
            if (publishReturnTo) publishReturnTo.value = article.return_to;
            if (generateButton) generateButton.setAttribute('data-article-id', String(article.id));
            if (commentTextarea) {
              commentTextarea.value = '';
            }
            if (commentLength) {
              commentLength.textContent = '0';
            }
            if (article.return_to && window.history && window.history.replaceState) {
              window.history.replaceState({}, '', article.return_to);
            }
          })
          .catch(function () {
            window.location.href = data.followBase + 'url=' + encodeURIComponent(data.url) + '&' + data.followParams;
          });
      });
    })();

    (function () {
      var button = document.querySelector('[data-generate-comment]');
      if (!button) return;
      var status = document.querySelector('[data-comment-status]');
      var textarea = document.getElementById('article-comment');
      var csrf = '{{ csrf }}';
      var basePath = '{{ base_path }}';
      var modeSelect = document.getElementById('article-generate-mode');
      var lengthEl = document.getElementById('article-comment-length');

      button.addEventListener('click', function () {
        var articleId = button.getAttribute('data-article-id');
        if (!articleId || !textarea) return;
        button.disabled = true;
        if (status) status.textContent = 'Generating...';
        var body = new URLSearchParams();
        body.set('_csrf', csrf);
        if (modeSelect && modeSelect.value) {
          body.set('mode', modeSelect.value);
        }
        fetch(basePath + '/articles/' + articleId + '/comment', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: body.toString()
        })
          .then(function (res) { return res.text(); })
          .then(function (text) {
            textarea.value = text;
            if (lengthEl) lengthEl.textContent = String(text.length);
            if (status) status.textContent = '';
          })
          .catch(function () {
            if (status) status.textContent = 'Failed to generate.';
          })
          .finally(function () {
            button.disabled = false;
          });
      });

      if (textarea && lengthEl) {
        textarea.addEventListener('input', function () {
          lengthEl.textContent = String(textarea.value.length);
        });
      }
    })();
  </script>
{% endblock %}

{% extends "layout.twig" %}

{% block content %}
  <style>
    .reader {
      display: flex;
      gap: 24px;
      align-items: start;
    }
    .reader__content {
      flex: 2;
      min-width: 0;
    }
    .reader__sidebar {
      flex: 1;
      min-width: 260px;
    }
    .reader__meta {
      margin-bottom: 16px;
    }
    .reader__article {
      padding: 32px;
    }
    .reader__content article {
      line-height: 1.8;
      font-size: 18px;
    }
    .reader__content article h1,
    .reader__content article h2,
    .reader__content article h3 {
      margin-top: 1.4em;
      margin-bottom: 0.5em;
    }
    .reader__content article p:last-child {
      margin-bottom: 0;
    }
    @media (max-width: 900px) {
      .reader {
        flex-direction: column;
      }
    }
  </style>

  <div class="reader">
    <div class="reader__content">
      <div class="card hero-card reader__meta">
        <span class="eyebrow">{{ article.feed_name }}</span>
        <h1 style="margin-bottom: 10px;">{{ article.title }}</h1>
        <div class="actions-row">
          <span class="muted">{{ article.published_at ?: article.created_at }}</span>
          <a href="{{ article.url }}" target="_blank" rel="noopener">Open original</a>
        </div>
      </div>
      <div class="card reader__article">
        <article>
          {{ article.content_html|raw }}
        </article>
      </div>
    </div>
    <aside class="reader__sidebar">
      <div class="card">
        <span class="eyebrow">Compose</span>
        <h2>Schedule a response</h2>
        {% if saved %}
          <p class="status-pill">Post scheduled</p>
        {% elseif status == 'duplicate_ignored' %}
          <p class="status-pill">Duplicate submit ignored</p>
        {% elseif error %}
          <p class="status-pill">Comment, schedule time, and at least one account are required</p>
        {% endif %}
        <form method="post" action="{{ base_path }}/posts" class="form-stack">
          <input type="hidden" name="_csrf" value="{{ csrf }}" />
          <input type="hidden" name="_submit_token" value="{{ submit_token }}" />
          <input type="hidden" name="article_id" value="{{ article.id }}" />
          <input type="hidden" name="return_to" value="{{ base_path }}/articles/{{ article.id }}" />
          <label>
            Comment
            <textarea name="comment" rows="6" style="width: 100%;"></textarea>
          </label>
          <label>
            Schedule ({{ schedule_timezone }})
            <input id="reader-schedule" type="datetime-local" name="scheduled_at" value="{{ default_schedule_input }}" />
          </label>
          <fieldset>
            <legend>Accounts</legend>
            {% if accounts|length == 0 %}
              <p class="muted">No active accounts yet.</p>
            {% else %}
              <div class="stack" style="gap: 10px;">
              {% for account in accounts %}
                <label class="checkbox-row">
                  <input type="checkbox" name="account_ids[]" value="{{ account.id }}" />
                  {{ account.platform }} · {{ account.display_name }} ({{ account.handle }})
                </label>
              {% endfor %}
              </div>
            {% endif %}
          </fieldset>
          <div class="actions-row">
            <button type="submit" name="action" value="schedule">Schedule</button>
            <button type="submit" name="action" value="now" class="button-secondary">Share now</button>
          </div>
        </form>
      </div>
    </aside>
  </div>
{% endblock %}

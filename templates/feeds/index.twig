{% extends "layout.twig" %}

{% block content %}
  <div class="page-header">
    <div>
      <h1 class="page-title">Feeds</h1>
      <p class="page-subtitle muted">Track the publications and blogs behind your queue.</p>
    </div>
    <div class="actions-row">
      <a href="{{ base_path }}/feeds/new">Add feed</a>
    </div>
  </div>
  {% if status == 'imported' %}
    <div class="card" style="margin-bottom: 18px;">
      <p class="muted" style="margin-bottom: 0;">Imported {{ imported }} feeds. Skipped {{ skipped }} duplicates.</p>
    </div>
  {% elseif error == 'upload_failed' %}
    <div class="card" style="margin-bottom: 18px;">
      <p class="status-pill">Upload failed. Please choose an OPML file exported from NewsBlur.</p>
    </div>
  {% elseif error == 'invalid_opml' %}
    <div class="card" style="margin-bottom: 18px;">
      <p class="status-pill">The file could not be parsed as a valid OPML feed export.</p>
    </div>
  {% endif %}
  <div class="card" style="margin-bottom: 18px;">
    <div class="page-header" style="margin-bottom: 14px;">
      <div>
        <h2 style="margin-bottom: 8px;">Import from NewsBlur</h2>
        <p class="muted" style="margin-bottom: 0;">Export your sites from NewsBlur as OPML, then upload the file here.</p>
      </div>
    </div>
    <form method="post" action="{{ base_path }}/feeds/import" enctype="multipart/form-data" class="form-stack">
      <input type="hidden" name="_csrf" value="{{ csrf }}" />
      <label>
        OPML file
        <input type="file" name="opml_file" accept=".opml,.xml,text/xml,application/xml" required />
      </label>
      <div class="actions-row">
        <button type="submit">Import feeds</button>
      </div>
    </form>
  </div>
  <div class="card">
    {% if feeds|length == 0 %}
      <div class="empty-state muted">No feeds yet.</div>
    {% else %}
      <div class="table-shell">
        <table>
          <thead>
            <tr>
              <th>Name</th>
              <th>URL</th>
              <th>Active</th>
              <th>Last fetched</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {% for feed in feeds %}
              <tr>
                <td><strong>{{ feed.name }}</strong></td>
                <td>
                  <a href="{{ feed.url }}" target="_blank" rel="noopener">{{ feed.url }}</a>
                </td>
                <td>
                  <span class="status-pill">{{ feed.is_active ? 'Active' : 'Paused' }}</span>
                </td>
                <td>{{ feed.last_fetched_at ?: '—' }}</td>
                <td>
                  <div class="actions-row">
                    <a href="{{ base_path }}/feeds/{{ feed.id }}/edit">Edit</a>
                    <form method="post" action="{{ base_path }}/feeds/{{ feed.id }}/toggle" class="inline-form">
                      <input type="hidden" name="_csrf" value="{{ csrf }}" />
                      <button type="submit" class="button-secondary">{{ feed.is_active ? 'Disable' : 'Enable' }}</button>
                    </form>
                    <form method="post" action="{{ base_path }}/feeds/{{ feed.id }}/fetch" class="inline-form">
                      <input type="hidden" name="_csrf" value="{{ csrf }}" />
                      <button type="submit" class="button-secondary">Fetch now</button>
                    </form>
                    <form method="post" action="{{ base_path }}/feeds/{{ feed.id }}/delete" class="inline-form">
                      <input type="hidden" name="_csrf" value="{{ csrf }}" />
                      <button type="submit" class="button-secondary">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endif %}
  </div>
{% endblock %}

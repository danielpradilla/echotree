{% extends "layout.twig" %}

{% block content %}
  <style>
    .feeds-table th,
    .feeds-table td {
      padding: 10px 12px;
      font-size: 14px;
    }
    .feeds-table th {
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .feeds-table__name strong {
      font-size: 13px;
      line-height: 1.2;
    }
    .feed-name {
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }
    .stale-dot {
      width: 9px;
      height: 9px;
      border-radius: 999px;
      background: #cc3d2b;
      box-shadow: 0 0 0 3px rgba(204, 61, 43, 0.14);
      flex: 0 0 auto;
    }
    .feeds-table__url {
      max-width: 0;
      width: 100%;
    }
    .feeds-table__url a {
      display: inline-block;
      max-width: 100%;
      font-size: 12px;
      line-height: 1.3;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      vertical-align: top;
    }
    .feeds-table__date {
      font-size: 12px;
      white-space: nowrap;
    }
    .feeds-table__actions {
      width: 190px;
      vertical-align: top;
    }
    .feeds-table__actions-row {
      display: flex;
      flex-wrap: wrap;
      justify-content: flex-end;
      gap: 8px 6px;
    }
    .feeds-table__actions-row a,
    .feeds-table__actions-row button {
      font-size: 12px;
      line-height: 1.1;
      min-height: 30px;
    }
    .feeds-table__actions-row a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 6px 10px;
      border: 1px solid var(--border-color);
      border-radius: 999px;
      text-decoration: none;
      color: var(--accent-color);
      background: var(--surface-color);
    }
    .feeds-table__actions-row button {
      width: auto;
      padding: 6px 10px;
      border-radius: 999px;
    }
    .feeds-table__actions-row form {
      width: auto;
    }
    @media (max-width: 900px) {
      .feeds-table__url {
        max-width: 220px;
      }
      .feeds-table__actions {
        width: 170px;
      }
    }
  </style>
  <div class="page-header">
    <div>
      <h1 class="page-title">Feeds</h1>
      <p class="page-subtitle muted">Track the publications and blogs behind your queue.</p>
    </div>
    <div class="actions-row">
      <form method="post" action="{{ base_path }}/feeds/fetch-all" class="inline-form">
        <input type="hidden" name="_csrf" value="{{ csrf }}" />
        <button type="submit">Fetch all</button>
      </form>
      <a href="{{ base_path }}/feeds/new">Add feed</a>
    </div>
  </div>
  {% if status == 'imported' %}
    <div class="card" style="margin-bottom: 18px;">
      <p class="muted" style="margin-bottom: 0;">Imported {{ imported }} feeds. Skipped {{ skipped }} duplicates.</p>
    </div>
  {% elseif status == 'fetch_started' %}
    <div class="card" style="margin-bottom: 18px;">
      <p class="muted" style="margin-bottom: 0;">Feed refresh started in the background. It runs as a lightweight batch, so click again later if you want to continue through the rest of the list.</p>
    </div>
  {% elseif status == 'fetch_complete' %}
    <div class="card" style="margin-bottom: 18px;">
      <p class="muted" style="margin-bottom: 0;">Feed refreshed successfully.</p>
    </div>
  {% elseif status == 'fetch_checked' %}
    <div class="card" style="margin-bottom: 18px;">
      <p class="muted" style="margin-bottom: 0;">Feed checked. No new items were imported.</p>
    </div>
  {% elseif status == 'fetch_failed' %}
    <div class="card" style="margin-bottom: 18px;">
      <p class="status-pill">Feed fetch failed.</p>
    </div>
  {% elseif error == 'upload_failed' %}
    <div class="card" style="margin-bottom: 18px;">
      <p class="status-pill">Upload failed. Please choose a valid OPML export file.</p>
    </div>
  {% elseif error == 'invalid_opml' %}
    <div class="card" style="margin-bottom: 18px;">
      <p class="status-pill">The file could not be parsed as a valid OPML feed export.</p>
    </div>
  {% endif %}
  <div class="card" style="margin-bottom: 18px;">
    <div class="page-header" style="margin-bottom: 14px;">
      <div>
        <h2 style="margin-bottom: 8px;">Import from OPML</h2>
        <p class="muted" style="margin-bottom: 0;">Upload an OPML export file to import your sites here.</p>
      </div>
    </div>
    <form method="post" action="{{ base_path }}/feeds/import" enctype="multipart/form-data" class="form-stack">
      <input type="hidden" name="_csrf" value="{{ csrf }}" />
      <label>
        OPML file
        <input type="file" name="opml_file" accept=".opml,.xml,text/xml,application/xml" required />
      </label>
      <div class="actions-row">
        <button type="submit">Import feeds</button>
      </div>
    </form>
  </div>
  <div class="card">
    {% if feeds|length == 0 %}
      <div class="empty-state muted">No feeds yet.</div>
    {% else %}
      <div class="table-shell feeds-table">
        <table>
          <thead>
            <tr>
              <th>Name</th>
              <th>URL</th>
              <th>Active</th>
              <th>Last fetched</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {% for feed in feeds %}
              <tr>
                <td class="feeds-table__name">
                  <span class="feed-name">
                    <strong>{{ feed.name }}</strong>
                    {% if feed.is_stale %}
                      <span class="stale-dot" title="This feed has not been fetched in more than 6 months." aria-label="Stale feed"></span>
                    {% endif %}
                  </span>
                </td>
                <td class="feeds-table__url">
                  <a href="{{ feed.url }}" target="_blank" rel="noopener">{{ feed.url }}</a>
                </td>
                <td>
                  <span class="status-pill">{{ feed.is_active ? 'Active' : 'Paused' }}</span>
                </td>
                <td class="feeds-table__date">{{ feed.last_fetched_at ?: '—' }}</td>
                <td class="feeds-table__actions">
                  <div class="feeds-table__actions-row">
                    <a href="{{ base_path }}/feeds/{{ feed.id }}/edit">Edit</a>
                    <form method="post" action="{{ base_path }}/feeds/{{ feed.id }}/toggle" class="inline-form">
                      <input type="hidden" name="_csrf" value="{{ csrf }}" />
                      <button type="submit" class="button-secondary">{{ feed.is_active ? 'Disable' : 'Enable' }}</button>
                    </form>
                    <form method="post" action="{{ base_path }}/feeds/{{ feed.id }}/fetch" class="inline-form">
                      <input type="hidden" name="_csrf" value="{{ csrf }}" />
                      <button type="submit" class="button-secondary">Fetch now</button>
                    </form>
                    <form method="post" action="{{ base_path }}/feeds/{{ feed.id }}/delete" class="inline-form">
                      <input type="hidden" name="_csrf" value="{{ csrf }}" />
                      <button type="submit" class="button-secondary">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endif %}
  </div>
{% endblock %}

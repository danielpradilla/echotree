{% extends "layout.twig" %}

{% block content %}
  <div class="card" style="width: 100%; max-width: 360px; padding: 28px;">
    <h1 class="page-title" style="font-size: 32px; margin-bottom: 8px;">EchoTree</h1>
    <p class="muted" style="margin-bottom: 20px;">Sign in</p>
    {% if error %}
      <p class="status-pill" style="margin-bottom: 16px;">{{ error }}</p>
    {% endif %}
    <form method="post" action="{{ base_path }}/login" class="form-stack">
      <input type="hidden" name="_csrf" value="{{ csrf }}" />
      <label>
        Username
        <input type="text" name="username" required autofocus />
      </label>
      <label>
        Password
        <input type="password" name="password" required />
      </label>
      <div class="actions-row">
        <button type="submit" style="width: 100%;">Sign in</button>
      </div>
    </form>
  </div>
{% endblock %}

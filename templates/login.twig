{% extends "layout.twig" %}

{% block content %}
  <div class="page-header">
    <div>
      <h1 class="page-title">Sign in to EchoTree</h1>
      <p class="page-subtitle muted">Access your queue, accounts, and scheduled posts.</p>
    </div>
  </div>
  <div class="card" style="max-width: 520px;">
    {% if error %}
      <p class="status-pill">{{ error }}</p>
    {% endif %}
    <form method="post" action="{{ base_path }}/login" class="form-stack">
      <input type="hidden" name="_csrf" value="{{ csrf }}" />
      <label>
        Username
        <input type="text" name="username" required />
      </label>
      <label>
        Password
        <input type="password" name="password" required />
      </label>
      <div class="actions-row">
        <button type="submit">Sign in</button>
      </div>
    </form>
  </div>
{% endblock %}
